---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "LeverHub — It starts with you, not the charts",
  description = "A personal finance, markets and trading academy that helps you understand your situation, learn how money and markets move, take control and build a better work-life balance.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0e2750" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title}</title>
    <script is:inline>document.documentElement.classList.add("js");</script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Poppins:wght@400;500;600;700&family=Space+Mono:wght@400;700&family=Tilt+Warp&display=swap"
    />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <slot />
    <script>
      // Scroll-reveal for elements tagged .reveal
      const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const targets = [...document.querySelectorAll(".reveal")];
      if (reduced || !("IntersectionObserver" in window)) {
        targets.forEach((el) => el.classList.add("in"));
      } else {
        // Reveal anything already in view synchronously, then observe the rest.
        const vh = window.innerHeight;
        targets.forEach((el) => {
          const rect = el.getBoundingClientRect();
          if (rect.top < vh && rect.bottom > 0) el.classList.add("in");
        });
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("in");
                io.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.12 },
        );
        targets.filter((el) => !el.classList.contains("in")).forEach((el) => io.observe(el));
      }
    </script>
  </body>
</html>
