---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "LeverHub — It starts with you, not the charts",
  description = "A personal finance, markets and trading academy. Learn how the economy and markets work step by step, with a real coach, a dashboard and a trading journal.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0e2750" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title}</title>
    <script is:inline>document.documentElement.classList.add("js");</script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap"
    />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <slot />
    <script>
      // Motion engine: scroll reveals, staggered grids and count-up numbers.
      const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const targets = [...document.querySelectorAll<HTMLElement>(".reveal, .stagger")];

      const counters = new WeakSet<Element>();
      const runCounters = (scope: Element) => {
        scope.querySelectorAll<HTMLElement>("[data-count]").forEach((el) => {
          if (counters.has(el)) return;
          counters.add(el);
          const target = parseInt(el.dataset.count || "0", 10);
          if (reduced) {
            el.textContent = String(target);
            return;
          }
          const duration = 1300;
          const start = performance.now();
          const tick = (now: number) => {
            const progress = Math.min((now - start) / duration, 1);
            const eased = 1 - Math.pow(1 - progress, 3);
            el.textContent = String(Math.round(eased * target));
            if (progress < 1) requestAnimationFrame(tick);
          };
          requestAnimationFrame(tick);
        });
      };

      const show = (el: Element) => {
        el.classList.add("in");
        runCounters(el);
      };

      if (reduced || !("IntersectionObserver" in window)) {
        targets.forEach(show);
      } else {
        // Reveal anything already in view synchronously, then observe the rest.
        const vh = window.innerHeight;
        targets.forEach((el) => {
          const rect = el.getBoundingClientRect();
          if (rect.top < vh && rect.bottom > 0) show(el);
        });
        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                show(entry.target);
                io.unobserve(entry.target);
              }
            }
          },
          { threshold: 0.12 },
        );
        targets.filter((el) => !el.classList.contains("in")).forEach((el) => io.observe(el));
      }
    </script>
  </body>
</html>
