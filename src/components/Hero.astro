---
// Hero — centered, text-only, light. Full first screen so the trust strip
// below lands at the bottom of the viewport without scrolling.
---

<section class="hero" id="top">
  <div class="container inner">
    <div class="intro">
      <h1>
        <span class="line"><span class="line-inner">The academy that</span></span>
        <span class="line"><span class="line-inner">starts with you.</span></span>
      </h1>

      <p class="tagline rise" style="--d: 0.35s">
        A personal finance, markets and trading academy.
      </p>

      <p class="descriptor rise" style="--d: 0.45s">
        Begin with a short Snapshot of where you stand. Learn step by step, with a real
        coach beside you.
      </p>

      <div class="actions rise" style="--d: 0.55s">
        <a href="#hub" class="btn btn-teal">Start My LeverHub Journey</a>
        <a href="#video" class="btn btn-outline">Watch the intro</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: grid;
    align-items: center;
    /* Full first screen minus the trust strip below it */
    min-height: calc(100svh - 76px);
    background-color: var(--paper);
    border-bottom: 1px solid var(--line);
    padding-top: clamp(6.5rem, 10vw, 8.5rem);
    padding-bottom: clamp(3rem, 5vw, 4.5rem);
  }

  .inner {
    display: grid;
    justify-items: center;
    text-align: center;
  }

  /* No max-width here — the h1's nowrap lines can be wider than a fixed cap
     at large viewports, and a cap narrower than the content triggers the
     browser's overflow-safe centering fallback (silently left-aligns). Only
     the descriptor needs a line-length cap, applied directly on it below. */
  .intro {
    display: grid;
    gap: 1.5rem;
    justify-items: center;
  }

  h1 {
    color: var(--ink-black);
  }

  .line {
    display: block;
    overflow: hidden;
    white-space: nowrap;
    padding-bottom: 0.14em;
    margin-bottom: -0.14em;
  }

  .line-inner {
    display: block;
    transform: translateY(115%);
    transition: transform 0.9s var(--ease-out);
  }

  html.js .in .line-inner,
  html:not(.js) .line-inner {
    transform: none;
  }

  .line:nth-child(2) .line-inner {
    transition-delay: 0.12s;
  }

  .tagline {
    font-family: var(--font-sub);
    font-size: clamp(1.1rem, 1.8vw, 1.3rem);
    font-weight: 600;
    color: var(--navy);
  }

  .descriptor {
    color: var(--ink-75);
    font-size: 1.05rem;
    line-height: 1.7;
    max-width: 44ch;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.9rem;
    margin-top: 0.4rem;
  }

  .rise {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.8s var(--ease-out) var(--d, 0s), transform 0.8s var(--ease-out) var(--d, 0s);
  }

  html.js .in .rise,
  html:not(.js) .rise {
    opacity: 1;
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .line-inner,
    .rise {
      transform: none;
      opacity: 1;
      transition: none;
    }
  }

  @media (max-width: 900px) {
    .hero {
      min-height: calc(100svh - 120px);
    }

    h1 {
      white-space: normal;
    }

    .line {
      white-space: normal;
    }
  }
</style>

<script>
  const hero = document.getElementById("top");
  const show = () => hero?.classList.add("in");
  requestAnimationFrame(show);
  setTimeout(show, 400);
</script>
