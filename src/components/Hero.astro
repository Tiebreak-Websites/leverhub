---
// Hero — institutional light. Joins the Swiss system: graph-paper ground,
// navy headline + CTAs left, real product artifacts right (Balance Score card
// + learning-path sparkline), and a fact strip of true curriculum facts.
const facts = [
  "4-stage learning path",
  "5 course areas",
  "1:1 Progress Coach",
  "EN · PL, SWE & IT soon",
];
---

<section class="hero grid-paper" id="top">
  <div class="container inner">
    <div class="intro">
      <h1>
        <span class="line"><span class="line-inner">The academy that</span></span>
        <span class="line"><span class="line-inner">starts with you.</span></span>
      </h1>

      <p class="tagline rise" style="--d: 0.35s">
        A personal finance, markets and trading academy.
      </p>

      <p class="descriptor rise" style="--d: 0.45s">
        Begin with a short Snapshot of where you stand. Learn step by step, with a real
        coach beside you.
      </p>

      <div class="actions rise" style="--d: 0.55s">
        <a href="#hub" class="btn btn-teal">Start My LeverHub Journey</a>
        <a href="#video" class="btn btn-outline">Watch the intro</a>
      </div>
    </div>

    <div class="artifact reveal" aria-label="Illustration of the LeverHub platform: Balance Score and learning path">
      <div class="score-card">
        <span class="card-label">Balance Score</span>
        <div class="gauge">
          <svg viewBox="0 0 120 120" aria-hidden="true">
            <circle cx="60" cy="60" r="52" fill="none" stroke="rgba(255,255,255,0.14)" stroke-width="9"></circle>
            <circle
              class="ring"
              cx="60"
              cy="60"
              r="52"
              fill="none"
              stroke="#34d3ba"
              stroke-width="9"
              stroke-linecap="round"
              stroke-dasharray="327"
              stroke-dashoffset="327"
              transform="rotate(-90 60 60)"></circle>
          </svg>
          <span class="gauge-num" data-count="72" aria-hidden="true">0</span>
        </div>
        <span class="card-sub">Financial Control &middot; Time Balance &middot; Market Understanding</span>
      </div>

      <div class="spark-card">
        <span class="card-label dark">Learning path</span>
        <svg viewBox="0 0 220 64" preserveAspectRatio="none" aria-hidden="true">
          <polyline
            points="0,54 30,48 58,50 88,36 118,40 148,24 182,28 220,12"
            fill="none"
            stroke="#2fae9b"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"></polyline>
        </svg>
        <span class="card-steps">Snapshot &rarr; Courses &rarr; Practice</span>
      </div>
    </div>
  </div>

  <div class="container">
    <ul class="facts stagger">
      {facts.map((fact) => <li>{fact}</li>)}
    </ul>
  </div>
</section>

<style>
  .hero {
    background-color: var(--paper);
    border-bottom: 1px solid var(--line);
    padding-top: clamp(8rem, 12vw, 10.5rem);
    padding-bottom: clamp(3.5rem, 6vw, 5rem);
  }

  .inner {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(0, 1fr);
    gap: clamp(2.5rem, 6vw, 5rem);
    align-items: center;
  }

  .intro {
    display: grid;
    gap: 1.4rem;
    justify-items: start;
  }

  h1 {
    font-size: clamp(2.4rem, 5vw, 3.8rem);
    color: var(--ink-black);
  }

  .line {
    display: block;
    overflow: hidden;
    white-space: nowrap;
    padding-bottom: 0.14em;
    margin-bottom: -0.14em;
  }

  .line-inner {
    display: block;
    transform: translateY(115%);
    transition: transform 0.9s var(--ease-out);
  }

  html.js .in .line-inner,
  html:not(.js) .line-inner {
    transform: none;
  }

  .line:nth-child(2) .line-inner {
    transition-delay: 0.12s;
  }

  .tagline {
    font-family: var(--font-sub);
    font-size: clamp(1.1rem, 1.8vw, 1.3rem);
    font-weight: 600;
    color: var(--navy);
  }

  .descriptor {
    color: var(--ink-75);
    font-size: 1.05rem;
    line-height: 1.7;
    max-width: 38ch;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 0.4rem;
  }

  /* ---------- product artifacts ---------- */

  .artifact {
    position: relative;
    display: grid;
    justify-items: end;
    padding-bottom: 3.5rem;
  }

  .score-card {
    position: relative;
    z-index: 1;
    width: min(340px, 100%);
    display: grid;
    justify-items: center;
    gap: 0.9rem;
    background: var(--ink-black);
    border-radius: var(--radius);
    box-shadow: var(--shadow-lift);
    padding: 2rem 2rem 1.75rem;
    overflow: hidden;
  }

  .score-card::before {
    content: "";
    position: absolute;
    inset: -30% 40% -30% -20%;
    background: radial-gradient(60% 80% at 30% 50%, rgba(52, 211, 186, 0.2) 0%, rgba(52, 211, 186, 0) 70%);
    pointer-events: none;
  }

  .score-card > * {
    position: relative;
  }

  .card-label {
    font-family: var(--font-sub);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--teal-bright);
  }

  .card-label.dark {
    color: var(--teal-ink);
  }

  .gauge {
    position: relative;
    width: 116px;
    aspect-ratio: 1;
  }

  .ring {
    transition: stroke-dashoffset 1.5s var(--ease-out) 0.4s;
  }

  html.js .artifact.in .ring,
  html:not(.js) .ring {
    stroke-dashoffset: 92; /* 327 × (1 − 0.72) */
  }

  .gauge-num {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    font-family: var(--font-sub);
    font-size: 1.9rem;
    font-weight: 700;
    color: var(--white);
  }

  .card-sub {
    font-size: 0.72rem;
    font-weight: 500;
    text-align: center;
    color: var(--white-58);
  }

  /* Sparkline card overlaps the score card's lower-left corner */
  .spark-card {
    position: absolute;
    left: 0;
    bottom: 0;
    z-index: 2;
    width: min(250px, 78%);
    display: grid;
    gap: 0.6rem;
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    box-shadow: var(--shadow-card);
    padding: 1.1rem 1.25rem;
  }

  .spark-card svg {
    width: 100%;
    height: 52px;
  }

  .card-steps {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--ink-60);
  }

  /* ---------- fact strip ---------- */

  .facts {
    list-style: none;
    margin: clamp(3rem, 6vw, 4.5rem) 0 0;
    padding: 1.5rem 0 0;
    border-top: 1px solid var(--line);
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  .facts li {
    font-family: var(--font-sub);
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--ink-black);
    text-align: center;
  }

  .facts li:not(:first-child) {
    border-left: 1px solid var(--line);
  }

  /* Load-in rise for hero content */
  .rise {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.8s var(--ease-out) var(--d, 0s), transform 0.8s var(--ease-out) var(--d, 0s);
  }

  html.js .in .rise,
  html:not(.js) .rise {
    opacity: 1;
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .line-inner,
    .rise {
      transform: none;
      opacity: 1;
      transition: none;
    }

    .ring {
      transition: none;
      stroke-dashoffset: 92;
    }
  }

  @media (max-width: 900px) {
    .inner {
      grid-template-columns: 1fr;
    }

    .artifact {
      justify-items: center;
      padding-bottom: 3rem;
    }

    .spark-card {
      left: 8%;
    }

    .facts {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem 0;
    }

    .facts li:nth-child(3) {
      border-left: 0;
    }
  }
</style>

<script>
  const hero = document.getElementById("top");
  const show = () => hero?.classList.add("in");
  requestAnimationFrame(show);
  setTimeout(show, 400);
</script>
