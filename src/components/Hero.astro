---
// Hero — the site's one opening dark moment. Pure white two-row headline
// over the cinematic artwork; deepened near-black veil.
---

<section class="hero on-navy" id="top">
  <div class="bg" aria-hidden="true"></div>
  <div class="veil" aria-hidden="true"></div>

  <div class="container inner">
    <div class="intro">
      <h1>
        <span class="line"><span class="line-inner">It starts with you,</span></span>
        <span class="line"><span class="line-inner">not the charts.</span></span>
      </h1>

      <p class="tagline rise" style="--d: 0.4s">
        An online academy for personal finance, markets and trading &mdash; with a real
        coach, a dashboard and a trading journal.
      </p>

      <p class="descriptor rise" style="--d: 0.5s">
        You start with a short Snapshot of your money, time and habits. You learn how the
        economy and markets actually work. When you are ready, you connect a broker
        account and put it into practice &mdash; all in one place.
      </p>

      <div class="actions rise" style="--d: 0.6s">
        <a href="#hub" class="btn btn-teal">Start My LeverHub Journey</a>
        <a href="#video" class="btn btn-ghost">Watch the intro</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: grid;
    align-items: center;
    min-height: min(92vh, 880px);
    overflow: hidden;
    background: var(--ink-black);
    color: var(--white);
    padding-top: clamp(7rem, 11vw, 9rem);
    padding-bottom: clamp(5rem, 8vw, 7rem);
  }

  .bg {
    position: absolute;
    inset: 0;
    background-image: url("/images/hero.jpg");
    background-size: cover;
    background-position: 68% center;
    animation: kenburns 26s ease-in-out infinite alternate;
    will-change: transform;
  }

  @keyframes kenburns {
    from {
      transform: scale(1);
    }
    to {
      transform: scale(1.07);
    }
  }

  .veil {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(12, 30, 60, 0.92) 0%, rgba(12, 30, 60, 0.64) 38%, rgba(12, 30, 60, 0.1) 68%, rgba(12, 30, 60, 0.3) 100%),
      linear-gradient(180deg, rgba(12, 30, 60, 0.5) 0%, rgba(12, 30, 60, 0) 30%, rgba(12, 30, 60, 0.6) 100%);
  }

  .inner {
    position: relative;
  }

  .intro {
    display: grid;
    gap: 1.5rem;
    justify-items: start;
  }

  /* Exactly two rows, never wrapping — pure white */
  h1 {
    font-size: clamp(1.9rem, 7.6vw, 5.5rem);
    white-space: nowrap;
    color: var(--white);
  }

  .line {
    display: block;
    overflow: hidden;
    padding-bottom: 0.14em;
    margin-bottom: -0.14em;
  }

  .line-inner {
    display: block;
    transform: translateY(115%);
    transition: transform 0.9s var(--ease-out);
  }

  html.js .in .line-inner,
  html:not(.js) .line-inner {
    transform: none;
  }

  .line:nth-child(2) .line-inner {
    transition-delay: 0.12s;
  }

  .tagline {
    font-family: var(--font-sub);
    font-size: clamp(1.15rem, 1.9vw, 1.35rem);
    font-weight: 600;
    color: var(--white);
  }

  .descriptor {
    color: var(--white-75);
    font-size: 1.05rem;
    line-height: 1.7;
    max-width: 52ch;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 0.5rem;
  }

  .rise {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 0.8s var(--ease-out) var(--d, 0s), transform 0.8s var(--ease-out) var(--d, 0s);
  }

  html.js .in .rise,
  html:not(.js) .rise {
    opacity: 1;
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .bg {
      animation: none;
    }

    .line-inner,
    .rise {
      transform: none;
      opacity: 1;
      transition: none;
    }
  }

  @media (max-width: 900px) {
    .hero {
      min-height: 0;
    }

    .bg {
      background-position: 72% center;
    }
  }
</style>

<script>
  const hero = document.getElementById("top");
  const show = () => hero?.classList.add("in");
  requestAnimationFrame(show);
  setTimeout(show, 400);
</script>
