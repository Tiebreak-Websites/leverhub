---
const topics = [
  "How money works and what erodes it",
  "How the economy affects your daily life",
  "How global events move financial markets",
  "How trading works and how to build a structured routine",
  "How to connect your learning to real market activity",
];
---

<section class="section academy" id="academy">
  <div class="container inner">
    <div class="section-head reveal">
      <p class="eyebrow">The Academy</p>
      <h2>Learn how money and markets actually work</h2>
      <p class="lede">
        The LeverHub Academy covers everything you were never taught &mdash; in a sequence
        that makes sense.
      </p>
    </div>

    <div class="content">
      <ul class="topics reveal">
        {
          topics.map((topic) => (
            <li>
              <span class="check" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="14" height="14">
                  <path
                    fill="none"
                    stroke="currentColor"
                    stroke-width="3"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M4 12.5l5 5L20 6.5"
                  />
                </svg>
              </span>
              <span>{topic}</span>
            </li>
          ))
        }
      </ul>

      <aside class="callout reveal">
        <p class="quote">This is not passive content.</p>
        <p class="sub">It is a guided journey from understanding to action.</p>
      </aside>
    </div>
  </div>
</section>

<style>
  .academy {
    background: var(--white);
    border-block: 1px solid var(--mist);
  }

  .content {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: clamp(1.5rem, 4vw, 3.5rem);
    align-items: start;
  }

  .topics {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
  }

  .topics li {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.15rem 0.25rem;
    border-bottom: 1px solid var(--mist);
    font-family: var(--font-sub);
    font-weight: 500;
    font-size: 1.05rem;
    color: var(--ink);
  }

  .topics li:last-child {
    border-bottom: 0;
  }

  .check {
    flex: none;
    display: grid;
    place-items: center;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: var(--teal);
    color: var(--white);
  }

  .callout {
    background: var(--navy);
    color: var(--white);
    border-radius: var(--radius);
    padding: 2.25rem 2rem;
    display: grid;
    gap: 0.5rem;
    position: sticky;
    top: 110px;
  }

  .quote {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 2.4vw, 1.85rem);
    line-height: 1.2;
  }

  .sub {
    color: rgba(255, 255, 255, 0.75);
    font-size: 1rem;
  }

  @media (max-width: 820px) {
    .content {
      grid-template-columns: 1fr;
    }

    .callout {
      position: static;
    }
  }
</style>
