---
// Academy — cinematic media banner: the learner photo at its natural 4:3
// aspect fills a wide frame with a dark gradient band carrying the pull-quote
// in white. The five topics run beneath as ghost-numbered columns.
const topics = [
  "How money works and what erodes it",
  "How the economy affects your daily life",
  "How global events move financial markets",
  "How trading works and how to build a structured routine",
  "How to connect your learning to real market activity",
];
---

<section class="section academy" id="academy">
  <div class="container">
    <div class="section-head reveal">
      <h2>Learn how money and markets actually work</h2>
      <p class="lede">
        The LeverHub Academy covers everything you were never taught &mdash; in a sequence
        that makes sense.
      </p>
    </div>

    <figure class="media reveal">
      <img
        src="/images/people/learner.jpg"
        alt="A learner reviewing their finance dashboard at a desk in the evening"
        width="1200"
        height="900"
        loading="lazy"
      />
      <figcaption class="band">
        <span class="band-caps" aria-hidden="true">The LeverHub Academy</span>
        This is not passive content. It is a guided journey from understanding to action.
      </figcaption>
    </figure>

    <ol class="topics stagger">
      {
        topics.map((topic, i) => (
          <li>
            <span class="ghost" aria-hidden="true">0{i + 1}</span>
            <span class="topic">{topic}</span>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .academy {
    background: var(--white);
    border-block: 1px solid var(--line);
  }

  .media {
    position: relative;
    margin: 0 auto;
    max-width: 980px;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-lift);
  }

  /* Natural 4:3 source shown in a 21:9 window on wide screens would crop —
     so the frame follows the image: width 100%, height auto. Nothing cut. */
  .media img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Gradient band with the pull-quote — designed text-on-image */
  .band {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    padding: clamp(2.5rem, 5vw, 3.5rem) clamp(1.5rem, 3.5vw, 2.5rem) clamp(1.25rem, 3vw, 2rem);
    background: linear-gradient(180deg, rgba(10, 20, 40, 0) 0%, rgba(10, 20, 40, 0.72) 55%, rgba(10, 20, 40, 0.88) 100%);
    display: grid;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.1rem, 2.2vw, 1.55rem);
    line-height: 1.35;
    letter-spacing: -0.01em;
    color: var(--white);
  }

  .band-caps {
    font-family: var(--font-sub);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--teal-bright);
  }

  .topics {
    list-style: none;
    margin: clamp(2.5rem, 5vw, 3.5rem) 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: clamp(1.25rem, 2.5vw, 2rem);
  }

  .topics li {
    position: relative;
    display: grid;
    gap: 0.5rem;
    padding-top: 2.6rem;
    border-top: 2px solid var(--line);
    transition: border-color 0.25s ease;
  }

  .topics li:hover {
    border-top-color: var(--teal);
  }

  .ghost {
    position: absolute;
    top: 0.45rem;
    left: 0;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 2.4rem;
    line-height: 1;
    color: rgba(12, 26, 48, 0.1);
    user-select: none;
  }

  .topic {
    font-family: var(--font-sub);
    font-weight: 500;
    font-size: 0.95rem;
    line-height: 1.5;
    color: var(--ink);
  }

  @media (max-width: 960px) {
    .topics {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 520px) {
    .topics {
      grid-template-columns: 1fr;
    }
  }
</style>
