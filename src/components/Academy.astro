---
// Academy — compact split: photo left (4:3, gradient quote band on its lower
// edge), tight ghost-numbered topic list right. One-row title.
const topics = [
  "How money works and what erodes it",
  "How the economy affects your daily life",
  "How global events move financial markets",
  "How trading works and how to build a structured routine",
  "How to connect your learning to real market activity",
];
---

<section class="section tight academy" id="academy">
  <div class="container">
    <div class="section-head reveal">
      <h2 class="one-row">Learn how money and markets actually work</h2>
      <p class="lede">
        The LeverHub Academy covers everything you were never taught &mdash; in a sequence
        that makes sense.
      </p>
    </div>

    <div class="content">
      <figure class="media reveal">
        <img
          src="/images/people/learner.jpg"
          alt="A learner reviewing their finance dashboard at a desk in the evening"
          width="1200"
          height="900"
          loading="lazy"
        />
        <figcaption class="band">
          <span class="band-caps" aria-hidden="true">The LeverHub Academy</span>
          This is not passive content. It is a guided journey from understanding to action.
        </figcaption>
      </figure>

      <ol class="topics stagger">
        {
          topics.map((topic, i) => (
            <li>
              <span class="ghost" aria-hidden="true">0{i + 1}</span>
              <span class="topic">{topic}</span>
              <span class="tick" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 12.5l5 5L20 6.5" />
                </svg>
              </span>
            </li>
          ))
        }
      </ol>
    </div>
  </div>
</section>

<style>
  .academy {
    background: var(--white);
    border-block: 1px solid var(--line);
  }

  .content {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
    gap: clamp(2rem, 4.5vw, 3.75rem);
    align-items: center;
  }

  .media {
    position: relative;
    margin: 0;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-lift);
  }

  /* 4:3 — matches the source exactly, so nothing is cropped or stretched */
  .media img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
  }

  .band {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    padding: clamp(2.25rem, 4vw, 3rem) clamp(1.25rem, 2.5vw, 1.75rem) clamp(1.1rem, 2vw, 1.5rem);
    background: linear-gradient(180deg, rgba(12, 30, 60, 0) 0%, rgba(12, 30, 60, 0.72) 55%, rgba(12, 30, 60, 0.9) 100%);
    display: grid;
    gap: 0.4rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1rem, 1.6vw, 1.2rem);
    line-height: 1.4;
    letter-spacing: -0.01em;
    color: var(--white);
  }

  .band-caps {
    font-family: var(--font-sub);
    font-size: 0.66rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--teal-bright);
  }

  /* Tight numbered list — low vertical footprint */
  .topics {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
  }

  .topics li {
    display: flex;
    align-items: center;
    gap: 1.1rem;
    padding: 0.95rem 0.25rem;
    border-bottom: 1px solid var(--line);
    transition: padding-left 0.25s var(--ease-out);
  }

  .topics li:first-child {
    border-top: 1px solid var(--line);
  }

  .topics li:hover {
    padding-left: 0.75rem;
  }

  .ghost {
    flex: none;
    width: 2.4rem;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.7rem;
    line-height: 1;
    letter-spacing: -0.03em;
    color: rgba(12, 26, 48, 0.12);
    transition: color 0.25s ease;
    user-select: none;
  }

  .topics li:hover .ghost {
    color: var(--teal);
  }

  .topic {
    flex: 1;
    font-family: var(--font-sub);
    font-weight: 500;
    font-size: clamp(0.95rem, 1.4vw, 1.05rem);
    line-height: 1.45;
    color: var(--ink);
  }

  .tick {
    flex: none;
    display: grid;
    place-items: center;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    background: var(--teal-wash);
    color: var(--teal-deep);
  }

  @media (prefers-reduced-motion: reduce) {
    .topics li:hover {
      padding-left: 0.25rem;
    }
  }

  @media (max-width: 860px) {
    .content {
      grid-template-columns: 1fr;
    }
  }
</style>
