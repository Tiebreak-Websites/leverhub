---
// Academy — photo locked to a 4:3 box (object-fit: cover, can't stretch) with
// the pull-quote as an overlay card; numbered topic list beside it.
const topics = [
  "How money works and what erodes it",
  "How the economy affects your daily life",
  "How global events move financial markets",
  "How trading works and how to build a structured routine",
  "How to connect your learning to real market activity",
];
---

<section class="section academy" id="academy">
  <div class="container">
    <div class="section-head reveal">
      <h2>Learn how money and markets actually work</h2>
      <p class="lede">
        The LeverHub Academy covers everything you were never taught &mdash; in a sequence
        that makes sense.
      </p>
    </div>

    <div class="content">
      <figure class="media reveal">
        <img
          src="/images/people/learner.jpg"
          alt="A learner reviewing their finance dashboard at a desk in the evening"
          width="1200"
          height="900"
          loading="lazy"
        />
        <figcaption class="pull">
          This is not passive content. It is a guided journey from understanding to action.
        </figcaption>
      </figure>

      <ol class="topics stagger">
        {
          topics.map((topic, i) => (
            <li>
              <span class="num" aria-hidden="true">0{i + 1}</span>
              <span class="topic">{topic}</span>
              <span class="tick" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 12.5l5 5L20 6.5" />
                </svg>
              </span>
            </li>
          ))
        }
      </ol>
    </div>
  </div>
</section>

<style>
  .academy {
    background: var(--white);
    border-block: 1px solid var(--line);
  }

  .content {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.15fr);
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }

  .media {
    position: relative;
    margin: 0;
  }

  .media img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: var(--radius);
    box-shadow: var(--shadow-lift);
  }

  /* Pull-quote overlaid on the photo */
  .pull {
    position: absolute;
    left: 1.25rem;
    right: 1.25rem;
    bottom: 1.25rem;
    background: rgba(255, 255, 255, 0.94);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-left: 3px solid var(--teal);
    border-radius: var(--radius-sm);
    padding: 1rem 1.25rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(0.98rem, 1.4vw, 1.1rem);
    line-height: 1.45;
    color: var(--navy);
  }

  .topics {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
  }

  .topics li {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.3rem 0.25rem;
    border-bottom: 1px solid var(--line);
  }

  .topics li:first-child {
    border-top: 1px solid var(--line);
  }

  .num {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--teal-ink);
    flex: none;
  }

  .topic {
    font-family: var(--font-sub);
    font-weight: 500;
    font-size: clamp(1rem, 1.5vw, 1.1rem);
    color: var(--ink);
    flex: 1;
  }

  .tick {
    flex: none;
    display: grid;
    place-items: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--teal-wash);
    color: var(--teal-deep);
  }

  @media (max-width: 860px) {
    .content {
      grid-template-columns: 1fr;
    }
  }
</style>
