---
const quotes = [
  {
    text: "I always thought trading was for people who understood numbers. LeverHub showed me the numbers were never the problem. I just needed the right starting point.",
    name: "Marco R.",
    meta: "34 · Project Manager",
    initials: "MR",
  },
  {
    text: "The Snapshot was the first time I actually looked at my money honestly. That alone was worth it.",
    name: "Yuki T.",
    meta: "29 · Marketing Executive",
    initials: "YT",
  },
  {
    text: "I came for the trading. I stayed because LeverHub made me understand my whole financial situation.",
    name: "Amara S.",
    meta: "41 · Small Business Owner",
    initials: "AS",
  },
];
---

<section class="section voices">
  <div class="container">
    <div class="head reveal">
      <p class="eyebrow centered">Voices</p>
      <h2>A few words from people who started where you are</h2>
    </div>

    <div class="grid">
      {
        quotes.map((quote) => (
          <figure class="card quote reveal">
            <span class="qmark" aria-hidden="true">&ldquo;</span>
            <blockquote>{quote.text}</blockquote>
            <figcaption>
              <span class="avatar" aria-hidden="true">{quote.initials}</span>
              <span class="who">
                <span class="name">{quote.name}</span>
                <span class="meta">{quote.meta}</span>
              </span>
            </figcaption>
          </figure>
        ))
      }
    </div>

    <p class="fine center reveal">
      Individual experiences with the academy &mdash; not a promise of outcomes or trading results.
    </p>
  </div>
</section>

<style>
  .head {
    display: grid;
    gap: 1rem;
    justify-items: center;
    text-align: center;
    max-width: 640px;
    margin: 0 auto clamp(2.5rem, 5vw, 3.5rem);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .quote {
    margin: 0;
    padding: 1.9rem;
    display: grid;
    gap: 1.1rem;
    align-content: start;
  }

  .qmark {
    font-family: var(--font-display);
    font-size: 2.75rem;
    line-height: 0.6;
    color: var(--teal);
    display: block;
    margin-top: 0.7rem;
  }

  blockquote {
    margin: 0;
    font-size: 0.98rem;
    line-height: 1.65;
    color: var(--ink);
  }

  figcaption {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    border-top: 1px solid var(--mist);
    padding-top: 1.1rem;
  }

  .avatar {
    flex: none;
    display: grid;
    place-items: center;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: var(--navy);
    color: var(--white);
    font-family: var(--font-sub);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .who {
    display: grid;
    gap: 0.1rem;
  }

  .name {
    font-family: var(--font-sub);
    font-weight: 600;
    color: var(--navy);
  }

  .meta {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(12, 26, 48, 0.6);
  }

  .fine.center {
    margin-top: 1.5rem;
    text-align: center;
  }

  @media (max-width: 820px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
