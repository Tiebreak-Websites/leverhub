---
const quotes = [
  {
    text: "I always thought trading was for people who understood numbers. LeverHub showed me the numbers were never the problem. I just needed the right starting point.",
    name: "Marco R.",
    meta: "34 · Project Manager",
    initials: "MR",
  },
  {
    text: "The Snapshot was the first time I actually looked at my money honestly. That alone was worth it.",
    name: "Yuki T.",
    meta: "29 · Marketing Executive",
    initials: "YT",
  },
  {
    text: "I came for the trading. I stayed because LeverHub made me understand my whole financial situation.",
    name: "Amara S.",
    meta: "41 · Small Business Owner",
    initials: "AS",
  },
];
---

<section class="section voices">
  <div class="container">
    <div class="section-head center reveal">
      <h2>A few words from people who started where you are</h2>
    </div>

    <div class="grid stagger">
      {
        quotes.map((quote) => (
          <figure class="quote">
            <blockquote>{quote.text}</blockquote>
            <figcaption>
              <span class="avatar" aria-hidden="true">{quote.initials}</span>
              <span class="who">
                <span class="name">{quote.name}</span>
                <span class="meta">{quote.meta}</span>
              </span>
            </figcaption>
          </figure>
        ))
      }
    </div>

    <p class="fine center reveal">
      Individual experiences with the academy &mdash; not a promise of outcomes or trading results.
    </p>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(2rem, 5vw, 4rem);
  }

  .quote {
    margin: 0;
    display: grid;
    gap: 1.4rem;
    align-content: start;
    padding-top: 1.5rem;
    border-top: 2px solid var(--teal);
  }

  blockquote {
    margin: 0;
    font-family: var(--font-sub);
    font-weight: 500;
    font-size: 1.05rem;
    line-height: 1.65;
    color: var(--ink);
  }

  blockquote::before {
    content: "\201C";
  }

  blockquote::after {
    content: "\201D";
  }

  figcaption {
    display: flex;
    align-items: center;
    gap: 0.85rem;
  }

  .avatar {
    flex: none;
    display: grid;
    place-items: center;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: var(--navy);
    color: var(--white);
    font-family: var(--font-sub);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .who {
    display: grid;
    gap: 0.1rem;
  }

  .name {
    font-family: var(--font-sub);
    font-weight: 600;
    color: var(--navy);
  }

  .meta {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-60);
  }

  .fine.center {
    margin-top: clamp(2.5rem, 5vw, 3.5rem);
    text-align: center;
  }

  @media (max-width: 820px) {
    .grid {
      grid-template-columns: 1fr;
      gap: 2.25rem;
    }
  }
</style>
