---
const quotes = [
  {
    text: "I always thought trading was for people who understood numbers. LeverHub showed me the numbers were never the problem. I just needed the right starting point.",
    name: "Marco R.",
    meta: "34 · Project Manager",
    img: "/images/people/marco.jpg",
  },
  {
    text: "The Snapshot was the first time I actually looked at my finances honestly. That alone was worth it.",
    name: "Yuki T.",
    meta: "29 · Marketing Executive",
    img: "/images/people/yuki.jpg",
  },
  {
    text: "I came for the trading. I stayed because LeverHub made me understand my whole financial situation.",
    name: "Amara S.",
    meta: "41 · Small Business Owner",
    img: "/images/people/amara.jpg",
  },
];
---

<section class="section voices">
  <div class="container">
    <div class="section-head voices-head reveal">
      <span class="qghost" aria-hidden="true">&ldquo;</span>
      <h2>What members say</h2>
      <p class="lede">A few honest reflections from people who started where you are.</p>
    </div>

    <div class="grid stagger">
      {
        quotes.map((quote) => (
          <figure class="quote">
            <span class="mark" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M4.5 12.5c0-4 2.3-6.9 6-8l.9 1.8c-2.2 1-3.5 2.6-3.7 4.4.3-.1.7-.2 1.1-.2 1.8 0 3.1 1.3 3.1 3.1 0 1.9-1.4 3.3-3.3 3.3-2.4 0-4.1-1.9-4.1-4.4Zm9.5 0c0-4 2.3-6.9 6-8l.9 1.8c-2.2 1-3.5 2.6-3.7 4.4.3-.1.7-.2 1.1-.2 1.8 0 3.1 1.3 3.1 3.1 0 1.9-1.4 3.3-3.3 3.3-2.4 0-4.1-1.9-4.1-4.4Z"/></svg>
            </span>
            <blockquote>{quote.text}</blockquote>
            <figcaption>
              <img class="avatar" src={quote.img} alt="" width="480" height="480" loading="lazy" />
              <span class="who">
                <span class="name">{quote.name}</span>
                <span class="meta">{quote.meta}</span>
              </span>
            </figcaption>
          </figure>
        ))
      }
    </div>

    <p class="fine center reveal">
      Individual experiences with the academy &mdash; not a promise of outcomes or trading results.
    </p>
  </div>
</section>

<style>
  /* Giant ghost quotation mark behind the head — matches the FAQ head's
     ghost question mark treatment */
  .voices-head {
    position: relative;
    padding-top: 1.5rem;
  }

  .qghost {
    position: absolute;
    top: -3.75rem;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(9rem, 18vw, 13rem);
    line-height: 1;
    color: rgba(47, 174, 155, 0.09);
    pointer-events: none;
    user-select: none;
  }

  .voices-head h2,
  .voices-head .lede {
    position: relative;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    align-items: stretch;
  }

  /* Identical structure: mark / quote (flexes) / person pinned at bottom */
  .quote {
    margin: 0;
    display: grid;
    grid-template-rows: auto 1fr auto;
    gap: 1.25rem;
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: clamp(1.75rem, 3vw, 2.25rem);
    transition: transform 0.3s var(--ease-out), box-shadow 0.3s var(--ease-out);
  }

  .quote:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-lift);
  }

  .mark {
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-sm);
    background: var(--teal-wash);
    color: var(--teal-deep);
  }

  blockquote {
    margin: 0;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--ink);
  }

  figcaption {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding-top: 1.1rem;
    border-top: 1px solid var(--line);
  }

  .avatar {
    flex: none;
    width: 46px;
    height: 46px;
    border-radius: 50%;
    object-fit: cover;
  }

  .who {
    display: grid;
    gap: 0.05rem;
  }

  .name {
    font-family: var(--font-sub);
    font-weight: 600;
    color: var(--ink-black);
  }

  .meta {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--ink-60);
  }

  .fine.center {
    margin-top: clamp(2rem, 4vw, 3rem);
    text-align: center;
  }

  @media (prefers-reduced-motion: reduce) {
    .quote:hover {
      transform: none;
    }
  }

  @media (max-width: 820px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
