---
const quotes = [
  {
    text: "I always thought trading was for people who understood numbers. LeverHub showed me the numbers were never the problem. I just needed the right starting point.",
    name: "Marco R.",
    meta: "34 · Project Manager",
    initials: "MR",
  },
  {
    text: "The Snapshot was the first time I actually looked at my money honestly. That alone was worth it.",
    name: "Yuki T.",
    meta: "29 · Marketing Executive",
    initials: "YT",
  },
  {
    text: "I came for the trading. I stayed because LeverHub made me understand my whole financial situation.",
    name: "Amara S.",
    meta: "41 · Small Business Owner",
    initials: "AS",
  },
];
---

<section class="section voices">
  <div class="container">
    <div class="section-head reveal">
      <h2>A few words from people who started where you are</h2>
    </div>

    <div class="grid stagger">
      {
        quotes.map((quote) => (
          <figure class="card quote">
            <span class="qmark" aria-hidden="true">&ldquo;</span>
            <figcaption>
              <span class="avatar" aria-hidden="true">{quote.initials}</span>
              <span class="who">
                <span class="name">{quote.name}</span>
                <span class="meta">{quote.meta}</span>
              </span>
            </figcaption>
            <blockquote>{quote.text}</blockquote>
          </figure>
        ))
      }
    </div>

    <p class="fine reveal">
      Individual experiences with the academy &mdash; not a promise of outcomes or trading results.
    </p>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    align-items: start;
  }

  .quote {
    position: relative;
    margin: 0;
    padding: 2rem;
    display: grid;
    gap: 1.25rem;
    align-content: start;
    overflow: hidden;
    transition: transform 0.3s var(--ease-out), box-shadow 0.3s var(--ease-out);
  }

  .quote:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-lift);
  }

  /* Middle card raised on desktop for rhythm */
  .quote:nth-child(2) {
    transform: translateY(-1.25rem);
  }

  .quote:nth-child(2):hover {
    transform: translateY(calc(-1.25rem - 5px));
  }

  /* Oversized quotation watermark */
  .qmark {
    position: absolute;
    top: -0.4rem;
    right: 0.9rem;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 7rem;
    line-height: 1;
    color: var(--teal-wash);
    pointer-events: none;
  }

  figcaption {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    position: relative;
  }

  .avatar {
    flex: none;
    display: grid;
    place-items: center;
    width: 46px;
    height: 46px;
    border-radius: 50%;
    background: var(--navy);
    color: var(--white);
    font-family: var(--font-sub);
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .who {
    display: grid;
    gap: 0.1rem;
  }

  .name {
    font-family: var(--font-sub);
    font-weight: 600;
    color: var(--navy);
  }

  .meta {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-60);
  }

  blockquote {
    margin: 0;
    position: relative;
    font-size: 1rem;
    line-height: 1.7;
    color: var(--ink-75);
  }

  .fine {
    margin-top: clamp(2rem, 4vw, 3rem);
  }

  @media (prefers-reduced-motion: reduce) {
    .quote:hover,
    .quote:nth-child(2):hover {
      transform: none;
    }

    .quote:nth-child(2) {
      transform: none;
    }
  }

  @media (max-width: 820px) {
    .grid {
      grid-template-columns: 1fr;
    }

    .quote:nth-child(2),
    .quote:nth-child(2):hover {
      transform: none;
    }
  }
</style>
