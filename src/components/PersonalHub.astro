---
// Personal Hub — rebalanced bento: wide horizontal Snapshot (long copy flows
// sideways, not down), Goals + Coach as a pair, and the Balance Score as a
// full-width dark banner with the animated gauge.
---

<section class="section hub" id="hub">
  <div class="container">
    <div class="grid stagger">
      <div class="intro">
        <h2>Your LeverHub, built around your life</h2>
        <p class="lede">
          When you join, you get access to your Personal Hub &mdash; a space designed
          entirely around you. Four things live inside it.
        </p>
        <a href="#access" class="btn btn-teal">Open My Personal Hub <span class="arrow" aria-hidden="true">&rarr;</span></a>
      </div>

      <article class="card feature snapshot wash">
        <span class="icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="6.5" width="16" height="13" rx="2.5"/><path d="M9 6.5 10.2 4h3.6L15 6.5"/><circle cx="12" cy="12.8" r="3.2"/></svg>
        </span>
        <div class="body">
          <h3>Life &amp; Money Snapshot</h3>
          <p>
            Answer a few honest questions about your income, spending, time, stress and
            habits. LeverHub turns your answers into a clear picture of where you stand
            today &mdash; and where you can go.
          </p>
        </div>
      </article>

      <article class="card feature">
        <span class="icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M6 21V4"/><path d="M6 5h11.5l-2.6 3.5L17.5 12H6"/></svg>
        </span>
        <div class="body">
          <h3>Personal Goals</h3>
          <p>
            A car. A home. An emergency fund. A better routine. Define what you actually
            want &mdash; and connect it to your learning path.
          </p>
        </div>
      </article>

      <article class="card feature">
        <span class="icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="9.5" cy="9" r="3.2"/><path d="M3.8 19.5c.9-2.9 3-4.4 5.7-4.4 2.7 0 4.8 1.5 5.7 4.4"/><path d="M16 4.5a3.2 3.2 0 0 1 0 6.2M17.5 15.3c1.6.6 2.7 1.9 3.2 4.2"/></svg>
        </span>
        <div class="body">
          <h3>Progress Coach</h3>
          <p>
            A real person who helps you complete your Snapshot, define your goals,
            personalise your learning path and keep you moving forward.
          </p>
        </div>
      </article>

      <article class="card feature score reveal">
        <div class="gauge" role="img" aria-label="Illustrative LeverHub Balance Score of 72 out of 100">
          <svg viewBox="0 0 120 120" aria-hidden="true">
            <circle cx="60" cy="60" r="52" fill="none" stroke="rgba(255,255,255,0.14)" stroke-width="9"></circle>
            <circle
              class="ring"
              cx="60"
              cy="60"
              r="52"
              fill="none"
              stroke="#2fae9b"
              stroke-width="9"
              stroke-linecap="round"
              stroke-dasharray="327"
              stroke-dashoffset="327"
              transform="rotate(-90 60 60)"></circle>
          </svg>
          <span class="gauge-num" data-count="72" aria-hidden="true">0</span>
        </div>
        <div class="body">
          <h3>LeverHub Balance Score</h3>
          <p>
            Your personal score across five areas: Money Control, Time Balance, Market
            Understanding, Growth Readiness and Trading Readiness. It changes as you do.
          </p>
          <p class="note">You do not need to fill everything in on day one. The important thing is to start.</p>
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1.25rem;
  }

  .intro {
    grid-column: span 2;
    display: grid;
    gap: 1.2rem;
    align-content: center;
    justify-items: start;
    padding-right: clamp(0rem, 2vw, 1.5rem);
  }

  .intro h2 {
    max-width: 14ch;
  }

  .feature {
    padding: clamp(1.6rem, 3vw, 2rem);
    display: grid;
    gap: 1rem;
    align-content: start;
    transition: transform 0.3s var(--ease-out), box-shadow 0.3s var(--ease-out);
  }

  .feature:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-lift);
  }

  .feature .body {
    display: grid;
    gap: 0.55rem;
  }

  .feature .icon {
    display: grid;
    place-items: center;
    width: 46px;
    height: 46px;
    border-radius: 50%;
    background: var(--teal-wash);
    color: var(--teal-deep);
    flex: none;
  }

  .feature .icon svg {
    width: 24px;
    height: 24px;
  }

  .feature p {
    color: var(--ink-75);
    font-size: 0.95rem;
    line-height: 1.65;
  }

  /* Snapshot — wide horizontal card: long copy flows sideways */
  .snapshot {
    grid-column: span 4;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: 1.5rem;
  }

  .snapshot p {
    max-width: 62ch;
  }

  .feature.wash {
    background: var(--teal-wash);
    border-color: transparent;
  }

  .feature.wash .icon {
    background: var(--white);
  }

  /* Goals + Coach — the middle pair */
  .feature:not(.snapshot):not(.score) {
    grid-column: span 3;
  }

  /* Balance Score — full-width dark banner with the gauge */
  .score {
    grid-column: 1 / -1;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: clamp(1.5rem, 4vw, 3rem);
    background: var(--navy-deep);
    border-color: var(--navy-deep);
  }

  .score h3 {
    color: var(--white);
  }

  .score p {
    color: var(--white-75);
    max-width: 68ch;
  }

  .score .note {
    font-family: var(--font-sub);
    font-weight: 500;
    color: var(--teal);
    font-size: 1.02rem;
    margin-top: 0.35rem;
  }

  .gauge {
    position: relative;
    width: clamp(110px, 12vw, 136px);
    aspect-ratio: 1;
  }

  .ring {
    transition: stroke-dashoffset 1.5s var(--ease-out) 0.3s;
  }

  html.js .score.in .ring,
  html:not(.js) .ring {
    stroke-dashoffset: 92; /* 327 × (1 − 0.72) */
  }

  .gauge-num {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    font-family: var(--font-sub);
    font-size: 2.1rem;
    font-weight: 700;
    color: var(--white);
  }

  @media (prefers-reduced-motion: reduce) {
    .ring {
      transition: none;
      stroke-dashoffset: 92;
    }

    .feature:hover {
      transform: none;
    }
  }

  @media (max-width: 960px) {
    .grid {
      grid-template-columns: 1fr 1fr;
    }

    .intro,
    .snapshot,
    .score {
      grid-column: 1 / -1;
    }

    .feature:not(.snapshot):not(.score) {
      grid-column: span 1;
    }
  }

  @media (max-width: 640px) {
    .grid {
      grid-template-columns: 1fr;
    }

    .feature:not(.snapshot):not(.score) {
      grid-column: 1 / -1;
    }

    .snapshot,
    .score {
      grid-template-columns: 1fr;
      align-items: start;
    }
  }
</style>
