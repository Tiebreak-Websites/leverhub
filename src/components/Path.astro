---
// The LeverHub Path — four steps on a drawn journey line. Centered,
// diagrammatic: ghost numerals, icon nodes, a line that draws through them.
// (Steps 2 + 3 of the original copy merged into "Economy & markets".)
const steps = [
  {
    title: "Where you are",
    body: "A short assessment of your finances, time and habits.",
    icon: `<circle cx="12" cy="8.5" r="3.5"/><path d="M5.5 19.5c1-3.2 3.4-4.8 6.5-4.8s5.5 1.6 6.5 4.8"/>`,
  },
  {
    title: "Economy & markets",
    body: "Courses on inflation, rates and how markets move.",
    icon: `<path d="M7 8v8M7 6v2M7 16v2M12 5v6M12 3v2M12 11v2M17 10v8M17 8v2M17 18v2"/><rect x="5.5" y="9" width="3" height="5" rx="0.8"/><rect x="10.5" y="6" width="3" height="4" rx="0.8"/><rect x="15.5" y="11" width="3" height="5" rx="0.8"/>`,
  },
  {
    title: "Take action",
    body: "Choose a broker, connect it, keep a trading journal.",
    icon: `<path d="M13.5 3.5 6.5 13h4.5l-.5 7.5L17.5 11H13l.5-7.5Z"/>`,
  },
  {
    title: "Work-life balance",
    body: "Organise your finances, your work and your time.",
    icon: `<path d="M12 4v16M6 20h12M12 6.5 6.5 8M12 6.5 17.5 8M6.5 8 4 13a2.6 2.6 0 0 0 5 0L6.5 8ZM17.5 8 15 13a2.6 2.6 0 0 0 5 0L17.5 8Z"/>`,
  },
];
---

<section class="section path" id="path">
  <div class="container">
    <div class="section-head reveal">
      <h2 class="one-row">Four steps. <em>One direction.</em> Your pace.</h2>
      <p class="lede">Four stages, always in this order. You always know what comes next.</p>
    </div>

    <ol class="steps stagger">
      {
        steps.map((step, i) => (
          <li class="step">
            <span class="ghost" aria-hidden="true">0{i + 1}</span>
            <span class="node" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={step.icon} />
            </span>
            <h3>{step.title}</h3>
            <p>{step.body}</p>
          </li>
        ))
      }
    </ol>

    <p class="fine disclosure reveal">
      LeverHub is not a broker &mdash; broker accounts are opened directly with independent
      third parties. Trading involves risk, including the loss of capital.
    </p>
  </div>
</section>

<style>
  .path {
    background-color: var(--white);
    border-block: 1px solid var(--line);
  }

  .steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(1.5rem, 3vw, 2.5rem);
  }

  .step {
    position: relative;
    display: grid;
    gap: 0.6rem;
    justify-items: center;
    text-align: center;
    padding-top: 3.2rem;
  }

  /* Oversized ghost numeral behind each step */
  .ghost {
    position: absolute;
    top: -1.4rem;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(4.5rem, 8vw, 7rem);
    line-height: 1;
    color: rgba(12, 26, 48, 0.06);
    pointer-events: none;
    user-select: none;
  }

  /* Journey line drawing through the nodes */
  .step:not(:last-child)::after {
    content: "";
    position: absolute;
    top: calc(3.2rem + 33px);
    left: calc(50% + 46px);
    width: calc(100% + clamp(1.5rem, 3vw, 2.5rem) - 92px);
    border-top: 2px dashed rgba(47, 174, 155, 0.55);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.55s var(--ease-out);
  }

  html.js .steps.in .step:not(:last-child)::after,
  html:not(.js) .step:not(:last-child)::after {
    transform: scaleX(1);
  }

  html.js .steps.in .step:nth-child(1)::after { transition-delay: 0.25s; }
  html.js .steps.in .step:nth-child(2)::after { transition-delay: 0.5s; }
  html.js .steps.in .step:nth-child(3)::after { transition-delay: 0.75s; }

  .node {
    position: relative;
    display: grid;
    place-items: center;
    width: 66px;
    height: 66px;
    border-radius: 50%;
    border: 1.5px solid var(--teal);
    color: var(--teal-deep);
    background: var(--white);
    box-shadow: 0 0 0 6px rgba(47, 174, 155, 0.08);
    margin-bottom: 0.5rem;
    transition: transform 0.35s var(--ease-out), box-shadow 0.35s var(--ease-out);
  }

  .step:hover .node {
    transform: translateY(-4px);
    box-shadow: 0 0 0 8px rgba(47, 174, 155, 0.14);
  }

  .node svg {
    width: 28px;
    height: 28px;
  }

  h3 {
    font-size: 1.15rem;
    white-space: nowrap;
  }

  .step p {
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--ink-75);
    max-width: 30ch;
  }

  .disclosure {
    margin-top: clamp(2.5rem, 5vw, 3.5rem);
    text-align: center;
  }

  @media (prefers-reduced-motion: reduce) {
    .step:not(:last-child)::after {
      transform: none;
      transition: none;
    }

    .step:hover .node {
      transform: none;
    }
  }

  @media (max-width: 900px) {
    .steps {
      grid-template-columns: repeat(2, 1fr);
      gap: 2.5rem 1.5rem;
      max-width: 640px;
      margin-inline: auto;
    }

    .step::after {
      display: none;
    }
  }

  @media (max-width: 520px) {
    .steps {
      grid-template-columns: 1fr;
    }
  }
</style>
