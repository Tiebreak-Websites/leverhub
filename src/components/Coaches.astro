---
// Meet your Progress Coaches — one row of four gallery frames. Portraits are
// shown at their natural aspect ratio (width: 100%, height: auto) so nothing
// is ever cropped or stretched; labels sit below each photo.
// Real names/bios to be supplied by the team before launch.
const coaches = [
  { img: "/images/people/coach-1.jpg", focus: "Snapshot & Personal Goals", alt: "LeverHub Progress Coach portrait" },
  { img: "/images/people/coach-2.jpg", focus: "Money Control & Habits", alt: "LeverHub Progress Coach portrait" },
  { img: "/images/people/coach-3.jpg", focus: "Markets & Trading Readiness", alt: "LeverHub Progress Coach portrait" },
  { img: "/images/people/coach-4.jpg", focus: "Work-Life Balance", alt: "LeverHub Progress Coach portrait" },
];
---

<section class="section tight coaches">
  <div class="container">
    <div class="section-head reveal">
      <h2>Meet your Progress Coaches</h2>
      <p class="lede">
        A real person who helps you complete your Snapshot, define your goals, personalise
        your learning path and keep you moving forward.
      </p>
    </div>

    <div class="row stagger">
      {
        coaches.map((coach) => (
          <figure class="coach">
            <div class="frame">
              <img src={coach.img} alt={coach.alt} width="720" height="1139" loading="lazy" />
            </div>
            <figcaption>
              <span class="role">Progress Coach</span>
              <span class="focus">{coach.focus}</span>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>

<style>
  .row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(1.25rem, 2.5vw, 2rem);
  }

  .coach {
    margin: 0;
    display: grid;
    gap: 1rem;
    justify-items: center;
    text-align: center;
  }

  .frame {
    width: 100%;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-card);
    transition: transform 0.3s var(--ease-out), box-shadow 0.3s var(--ease-out);
  }

  .coach:hover .frame {
    transform: translateY(-5px);
    box-shadow: var(--shadow-lift);
  }

  /* Uniform 4:5 frames — mixed source ratios fill identically, faces anchored */
  .frame {
    aspect-ratio: 4 / 5;
  }

  .frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
  }

  figcaption {
    display: grid;
    gap: 0.2rem;
  }

  .role {
    font-family: var(--font-sub);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--teal-ink);
  }

  .focus {
    font-family: var(--font-sub);
    font-weight: 600;
    color: var(--ink-black);
    font-size: 1.02rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .coach:hover .frame {
      transform: none;
    }
  }

  @media (max-width: 900px) {
    .row {
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem 1.25rem;
    }
  }

  @media (max-width: 480px) {
    .row {
      grid-template-columns: 1fr;
      max-width: 340px;
      margin-inline: auto;
    }
  }
</style>
