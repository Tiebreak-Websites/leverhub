---
// Meet your Progress Coaches — horizontal profile cards (2×2). The photo sits
// in a fixed-width column with object-fit: cover, so it can never stretch.
// Real names/bios to be supplied by the team before launch.
const coaches = [
  { img: "/images/people/coach-1.jpg", focus: "Snapshot & Personal Goals", alt: "LeverHub Progress Coach portrait" },
  { img: "/images/people/coach-2.jpg", focus: "Money Control & Habits", alt: "LeverHub Progress Coach portrait" },
  { img: "/images/people/coach-3.jpg", focus: "Markets & Trading Readiness", alt: "LeverHub Progress Coach portrait" },
  { img: "/images/people/coach-4.jpg", focus: "Work-Life Balance", alt: "LeverHub Progress Coach portrait" },
];
---

<section class="section tight coaches">
  <div class="container">
    <div class="section-head reveal">
      <h2>Meet your Progress Coaches</h2>
      <p class="lede">
        A real person who helps you complete your Snapshot, define your goals, personalise
        your learning path and keep you moving forward.
      </p>
    </div>

    <div class="grid stagger">
      {
        coaches.map((coach) => (
          <article class="card coach">
            <div class="photo-box">
              <img src={coach.img} alt={coach.alt} width="720" height="1139" loading="lazy" />
            </div>
            <div class="info">
              <span class="role">Progress Coach</span>
              <h3>{coach.focus}</h3>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .coach {
    display: grid;
    grid-template-columns: 150px 1fr;
    overflow: hidden;
    transition: transform 0.3s var(--ease-out), box-shadow 0.3s var(--ease-out);
  }

  .coach:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lift);
  }

  .photo-box {
    position: relative;
    min-height: 170px;
    background: var(--navy-deep);
  }

  .photo-box img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
  }

  .info {
    display: grid;
    gap: 0.35rem;
    align-content: center;
    padding: 1.5rem 1.75rem;
  }

  .role {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--teal-ink);
  }

  .info h3 {
    font-size: 1.15rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .coach:hover {
      transform: none;
    }
  }

  @media (max-width: 860px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 440px) {
    .coach {
      grid-template-columns: 120px 1fr;
    }

    .info {
      padding: 1.1rem 1.25rem;
    }
  }
</style>
