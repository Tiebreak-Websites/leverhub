---
// FAQ — two-column layout: sticky title rail left, single-open numbered
// accordion right with animated answers.
const faqs = [
  {
    q: "What is LeverHub?",
    a: "LeverHub is a personal money, markets and trading academy. It is different from a standard trading academy because it starts with you — your situation, your goals and your work-life balance — before moving into financial markets and trading.",
  },
  {
    q: "Do I need trading experience to join?",
    a: "None. LeverHub is designed to be the starting point. You begin by understanding your own situation, then learn how money and markets work. Trading comes when you are ready for it.",
  },
  {
    q: "What is the Life & Money Snapshot?",
    a: "It is a short diagnostic inside your Personal Hub that gives you a clear picture of where you stand today across money, time, lifestyle and market readiness. It generates your LeverHub Balance Score and helps your Progress Coach personalise your learning path.",
  },
  {
    q: "What is the Progress Coach?",
    a: "A real person who works with you one-on-one to complete your Snapshot, define your goals and keep your journey moving in the right direction.",
  },
  {
    q: "Do I have to connect a broker account?",
    a: "No. You can use LeverHub as a standalone academy. But if you connect a broker account, your academy subscription is included for the duration of your connected access package — because that is LeverHub working as it was designed.",
  },
  {
    q: "Is LeverHub a broker?",
    a: "No. LeverHub is the academy, the dashboard, the journal and the progress platform. The broker is separate. LeverHub helps you choose one, connect it and use your market activity as part of your learning path.",
  },
];
---

<section class="section faq" id="faq">
  <div class="container inner">
    <div class="rail reveal">
      <h2>FAQ</h2>
      <p class="fine disclosure">
        LeverHub is not a broker and does not hold funds or execute trades. Broker
        accounts are opened directly with independent third parties. Trading involves
        risk, including the loss of capital.
      </p>
    </div>

    <div class="list stagger" data-accordion>
      {
        faqs.map((item, i) => (
          <details class="item" name="faq">
            <summary>
              <span class="num" aria-hidden="true">0{i + 1}</span>
              <span class="q">{item.q}</span>
              <span class="icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="16" height="16">
                  <path
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    d="M12 5v14M5 12h14"
                  />
                </svg>
              </span>
            </summary>
            <div class="answer">
              <p>{item.a}</p>
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>

<style>
  .faq {
    background: var(--white);
    border-block: 1px solid var(--line);
  }

  .inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 2fr);
    gap: clamp(2.5rem, 6vw, 5rem);
    align-items: start;
  }

  .rail {
    position: sticky;
    top: 110px;
    display: grid;
    gap: 1.5rem;
  }

  .rail h2 {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
  }

  .disclosure {
    max-width: 34ch;
  }

  .list {
    display: grid;
    border-top: 1px solid var(--line);
  }

  .item {
    border-bottom: 1px solid var(--line);
  }

  summary {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.5rem 0.25rem;
    cursor: pointer;
    list-style: none;
  }

  summary::-webkit-details-marker {
    display: none;
  }

  .num {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    color: var(--teal-ink);
    flex: none;
  }

  .q {
    flex: 1;
    font-family: var(--font-sub);
    font-weight: 600;
    font-size: clamp(1.02rem, 1.6vw, 1.15rem);
    color: var(--navy);
    transition: color 0.2s ease, transform 0.25s var(--ease-out);
  }

  summary:hover .q {
    color: var(--teal-deep);
    transform: translateX(4px);
  }

  .icon {
    flex: none;
    display: grid;
    place-items: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--teal-wash);
    color: var(--teal-deep);
    transition: transform 0.3s var(--ease-out), background-color 0.25s ease, color 0.25s ease;
  }

  .item[open] .icon {
    transform: rotate(45deg);
    background: var(--teal);
    color: var(--white);
  }

  .answer {
    padding: 0 0.25rem 1.6rem calc(0.25rem + 0.72rem + 1.25rem);
  }

  .answer p {
    color: var(--ink-75);
    max-width: 58ch;
    line-height: 1.7;
  }

  /* Answer slides in on open */
  html.js .item[open] .answer {
    animation: answer-in 0.35s var(--ease-out);
  }

  @keyframes answer-in {
    from {
      opacity: 0;
      transform: translateY(-6px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    html.js .item[open] .answer {
      animation: none;
    }

    summary:hover .q {
      transform: none;
    }
  }

  @media (max-width: 860px) {
    .inner {
      grid-template-columns: 1fr;
    }

    .rail {
      position: static;
      gap: 1rem;
    }

    .answer {
      padding-left: 0.25rem;
    }
  }
</style>

<script>
  // Single-open accordion: opening one item closes the others.
  // (The `name` attribute does this natively in new browsers; this is the fallback.)
  const items = [...document.querySelectorAll<HTMLDetailsElement>("[data-accordion] details")];
  items.forEach((item) =>
    item.addEventListener("toggle", () => {
      if (item.open) items.forEach((other) => other !== item && (other.open = false));
    }),
  );
</script>
