---
// Introduction video — centered "stage" treatment. The play button is the one
// call to action; heading and lede sit above the player.
// Final video pending: drop it at public/media/leverhub-intro.mp4 and replace
// the .player markup with:
//   <video controls preload="metadata" poster="/images/video-poster.jpg">
//     <source src="/media/leverhub-intro.mp4" type="video/mp4" />
//   </video>
---

<section class="section video-section" id="video">
  <div class="container">
    <div class="section-head center reveal">
      <h2>See how LeverHub puts <em>you</em> in the center</h2>
      <p class="lede">
        Watch this short video to understand how LeverHub turns your situation, goals and
        learning into real progress.
      </p>
    </div>

    <div class="stage reveal">
      <div class="player" data-player>
        <div class="poster" aria-hidden="true"></div>
        <div class="shade" aria-hidden="true"></div>
        <p class="caption">Your financial path<br />starts with <em>you.</em></p>
        <button class="play" type="button" data-video-cta aria-label="Play the LeverHub introduction video">
          <svg viewBox="0 0 24 24" width="28" height="28" aria-hidden="true">
            <path fill="currentColor" d="M8 5.5v13l11-6.5-11-6.5Z"></path>
          </svg>
        </button>
        <div class="controls" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="14" height="14"><path fill="currentColor" d="M8 5.5v13l11-6.5-11-6.5Z"></path></svg>
          <span class="track"><span class="track-fill"></span></span>
          <span class="time">0:00 / 1:45</span>
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 10v4h4l5 4V6l-5 4H4Z"/><path d="M16.5 9.5a4 4 0 0 1 0 5"/></svg>
        </div>
        <span class="soon" data-soon>Final video coming soon</span>
      </div>
    </div>
  </div>
</section>

<style>
  .video-section {
    padding-top: clamp(4rem, 7vw, 6rem);
  }

  h2 em {
    font-style: normal;
    color: var(--teal-deep);
  }

  .stage {
    max-width: 940px;
    margin-inline: auto;
  }

  .player {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: 0 2px 4px rgba(12, 26, 48, 0.08), 0 48px 96px -36px rgba(14, 39, 80, 0.55);
    background: var(--navy-deep);
  }

  .poster {
    position: absolute;
    inset: 0;
    background-image: url("/images/video-poster.jpg");
    background-size: cover;
    background-position: center;
    transition: transform 0.6s var(--ease-out);
  }

  .player:hover .poster {
    transform: scale(1.03);
  }

  .shade {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(14, 39, 80, 0.35) 0%, rgba(14, 39, 80, 0.05) 45%, rgba(14, 39, 80, 0.72) 100%);
  }

  .caption {
    position: absolute;
    left: clamp(1.25rem, 3vw, 2.25rem);
    top: clamp(1.1rem, 2.5vw, 2rem);
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 2.6vw, 1.9rem);
    line-height: 1.25;
    color: var(--white);
    text-shadow: 0 2px 18px rgba(6, 16, 34, 0.55);
  }

  .caption em {
    font-style: normal;
    color: var(--teal);
  }

  .play {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    display: grid;
    place-items: center;
    width: 84px;
    height: 84px;
    border: 0;
    border-radius: 50%;
    background: var(--teal);
    color: var(--white);
    cursor: pointer;
    box-shadow: 0 0 0 0 rgba(47, 174, 155, 0.4);
    transition: transform 0.25s var(--ease-out), background-color 0.2s ease;
    animation: pulse 2.6s ease-out infinite;
  }

  @keyframes pulse {
    0% {
      box-shadow: 0 0 0 0 rgba(47, 174, 155, 0.45);
    }
    70% {
      box-shadow: 0 0 0 24px rgba(47, 174, 155, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(47, 174, 155, 0);
    }
  }

  .play:hover {
    transform: translate(-50%, -50%) scale(1.08);
    background: var(--teal-deep);
  }

  .play svg {
    margin-left: 4px;
  }

  .controls {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    display: flex;
    align-items: center;
    gap: 0.9rem;
    padding: 0.85rem 1.25rem;
    color: var(--white-85);
    background: linear-gradient(180deg, transparent, rgba(6, 16, 34, 0.65));
  }

  .track {
    flex: 1;
    height: 3px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.25);
    overflow: hidden;
  }

  .track-fill {
    display: block;
    width: 12%;
    height: 100%;
    border-radius: 999px;
    background: var(--teal);
  }

  .time {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
  }

  .soon {
    position: absolute;
    left: 50%;
    bottom: 3.9rem;
    transform: translateX(-50%) translateY(8px);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--white);
    background: rgba(14, 39, 80, 0.85);
    border: 1px solid rgba(47, 174, 155, 0.5);
    border-radius: 999px;
    padding: 0.45rem 1rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .player.show-soon .soon {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .play {
      animation: none;
    }

    .player:hover .poster {
      transform: none;
    }
  }
</style>

<script>
  // Placeholder behavior until the final video is delivered.
  const player = document.querySelector("[data-player]");
  let timer: ReturnType<typeof setTimeout> | undefined;
  document.querySelectorAll("[data-video-cta]").forEach((el) =>
    el.addEventListener("click", () => {
      player?.classList.add("show-soon");
      clearTimeout(timer);
      timer = setTimeout(() => player?.classList.remove("show-soon"), 2400);
    }),
  );
</script>
