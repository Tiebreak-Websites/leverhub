---
// Introduction video — centered dark theater: title, lede and player all
// centered on the near-black stage with a soft teal glow.
// Final video pending: drop it at public/media/leverhub-intro.mp4 and replace
// the .player markup with:
//   <video controls preload="metadata" poster="/images/video-poster.jpg">
//     <source src="/media/leverhub-intro.mp4" type="video/mp4" />
//   </video>
---

<section class="section video-section on-navy" id="video">
  <div class="container">
    <div class="section-head reveal">
      <h2 class="one-row">LeverHub in two minutes</h2>
      <p class="lede">
        One short video of the Snapshot, the learning path, the dashboard and the coach.
      </p>
    </div>

    <div class="stage reveal">
      <div class="player" data-player>
        <div class="poster" aria-hidden="true"></div>
        <div class="shade" aria-hidden="true"></div>
        <button class="play" type="button" data-video-cta aria-label="Play the LeverHub introduction video">
          <svg viewBox="0 0 24 24" width="28" height="28" aria-hidden="true">
            <path fill="currentColor" d="M8 5.5v13l11-6.5-11-6.5Z"></path>
          </svg>
        </button>
        <div class="controls" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="14" height="14"><path fill="currentColor" d="M8 5.5v13l11-6.5-11-6.5Z"></path></svg>
          <span class="track"><span class="track-fill"></span></span>
          <span class="time">0:00 / 1:45</span>
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 10v4h4l5 4V6l-5 4H4Z"/><path d="M16.5 9.5a4 4 0 0 1 0 5"/></svg>
        </div>
        <span class="soon" data-soon>Final video coming soon</span>
      </div>
    </div>
  </div>
</section>

<style>
  .video-section {
    position: relative;
    overflow: hidden;
    background: var(--ink-black);
    padding-top: clamp(4.5rem, 8vw, 7rem);
    padding-bottom: clamp(5rem, 9vw, 8rem);
  }

  .stage {
    position: relative;
    max-width: 940px;
    margin-inline: auto;
  }

  .stage::before {
    content: "";
    position: absolute;
    inset: -14% -18%;
    background: radial-gradient(55% 55% at 50% 48%, rgba(52, 211, 186, 0.18) 0%, rgba(52, 211, 186, 0) 70%);
    pointer-events: none;
  }

  .player {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: 0 2px 4px rgba(2, 8, 20, 0.4), 0 48px 96px -36px rgba(2, 8, 20, 0.9);
    background: var(--ink-black);
  }

  .poster {
    position: absolute;
    inset: 0;
    background-image: url("/images/video-poster.jpg");
    background-size: cover;
    background-position: center;
    transition: transform 0.6s var(--ease-out);
  }

  .player:hover .poster {
    transform: scale(1.03);
  }

  .shade {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(10, 20, 40, 0.35) 0%, rgba(10, 20, 40, 0.05) 45%, rgba(10, 20, 40, 0.72) 100%);
  }

  .play {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    display: grid;
    place-items: center;
    width: 84px;
    height: 84px;
    border: 0;
    border-radius: 50%;
    background: var(--teal-bright);
    color: var(--ink-black);
    cursor: pointer;
    box-shadow: 0 0 0 0 rgba(52, 211, 186, 0.4);
    transition: transform 0.25s var(--ease-out), background-color 0.2s ease;
    animation: pulse 2.6s ease-out infinite;
  }

  @keyframes pulse {
    0% {
      box-shadow: 0 0 0 0 rgba(52, 211, 186, 0.45);
    }
    70% {
      box-shadow: 0 0 0 24px rgba(52, 211, 186, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(52, 211, 186, 0);
    }
  }

  .play:hover {
    transform: translate(-50%, -50%) scale(1.08);
    background: var(--teal);
  }

  .play svg {
    margin-left: 4px;
  }

  .controls {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    display: flex;
    align-items: center;
    gap: 0.9rem;
    padding: 0.85rem 1.25rem;
    color: var(--white-85);
    background: linear-gradient(180deg, transparent, rgba(2, 8, 20, 0.65));
  }

  .track {
    flex: 1;
    height: 3px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.25);
    overflow: hidden;
  }

  .track-fill {
    display: block;
    width: 12%;
    height: 100%;
    border-radius: 999px;
    background: var(--teal-bright);
  }

  .time {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.04em;
  }

  .soon {
    position: absolute;
    left: 50%;
    bottom: 3.9rem;
    transform: translateX(-50%) translateY(8px);
    font-family: var(--font-sub);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--white);
    background: rgba(10, 20, 40, 0.85);
    border: 1px solid rgba(52, 211, 186, 0.5);
    border-radius: 999px;
    padding: 0.45rem 1rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .player.show-soon .soon {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .play {
      animation: none;
    }

    .player:hover .poster {
      transform: none;
    }
  }
</style>

<script>
  const player = document.querySelector("[data-player]");
  let timer: ReturnType<typeof setTimeout> | undefined;
  document.querySelectorAll("[data-video-cta]").forEach((el) =>
    el.addEventListener("click", () => {
      player?.classList.add("show-soon");
      clearTimeout(timer);
      timer = setTimeout(() => player?.classList.remove("show-soon"), 2400);
    }),
  );
</script>
