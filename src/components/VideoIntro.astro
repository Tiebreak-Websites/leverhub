---
// Introduction video section (suggested by Andres) — layout per client reference.
// The final video has not been delivered yet: the player is a designed placeholder.
// When the cut arrives, drop it at public/media/leverhub-intro.mp4 and replace the
// .player markup with:
//   <video controls preload="metadata" poster="/images/video-poster.jpg">
//     <source src="/media/leverhub-intro.mp4" type="video/mp4" />
//   </video>
---

<section class="section video-section" id="video">
  <div class="container card panel reveal">
    <div class="copy">
      <p class="eyebrow">The intro</p>
      <h2>See how LeverHub puts <em>you</em> in the center</h2>
      <p class="lede">
        Watch this short video to understand how LeverHub turns your situation, goals and
        learning into real progress.
      </p>
      <button class="btn btn-teal watch" type="button" data-video-cta>
        Watch the video <span class="arrow" aria-hidden="true">&rarr;</span>
      </button>
    </div>

    <div class="player" data-player>
      <div class="poster" aria-hidden="true"></div>
      <div class="shade" aria-hidden="true"></div>
      <p class="caption">Your financial path<br />starts with <em>you.</em></p>
      <button class="play" type="button" data-video-cta aria-label="Play the LeverHub introduction video">
        <svg viewBox="0 0 24 24" width="26" height="26" aria-hidden="true">
          <path fill="currentColor" d="M8 5.5v13l11-6.5-11-6.5Z"></path>
        </svg>
      </button>
      <div class="controls" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="14" height="14"><path fill="currentColor" d="M8 5.5v13l11-6.5-11-6.5Z"></path></svg>
        <span class="time">0:00 / 1:45</span>
        <span class="spacer"></span>
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 10v4h4l5 4V6l-5 4H4Z"/><path d="M16.5 9.5a4 4 0 0 1 0 5"/></svg>
        <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="3"/><path d="M12 5v2M12 17v2M5 12h2M17 12h2M6.8 6.8l1.4 1.4M15.8 15.8l1.4 1.4M6.8 17.2l1.4-1.4M15.8 8.2l1.4-1.4"/></svg>
      </div>
      <span class="soon" data-soon>Final video coming soon</span>
    </div>
  </div>
</section>

<style>
  .video-section {
    padding-top: clamp(3.5rem, 6vw, 5rem);
  }

  .panel {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.45fr);
    gap: clamp(1.75rem, 4vw, 3.5rem);
    align-items: center;
    padding: clamp(1.75rem, 4vw, 3rem);
  }

  .copy {
    display: grid;
    gap: 1.1rem;
    justify-items: start;
  }

  h2 em {
    font-style: normal;
    color: var(--teal-deep);
  }

  .copy .lede {
    font-family: var(--font-sub);
    font-weight: 500;
    color: rgba(12, 26, 48, 0.75);
    font-size: 1.02rem;
    max-width: 38ch;
  }

  .watch {
    margin-top: 0.4rem;
  }

  .player {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow-lift);
    background: var(--navy-deep);
  }

  .poster {
    position: absolute;
    inset: 0;
    background-image: url("/images/video-poster.jpg");
    background-size: cover;
    background-position: center;
  }

  .shade {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(14, 39, 80, 0.35) 0%, rgba(14, 39, 80, 0.05) 45%, rgba(14, 39, 80, 0.72) 100%);
  }

  .caption {
    position: absolute;
    left: 2rem;
    top: 1.75rem;
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2.2vw, 1.7rem);
    line-height: 1.25;
    color: var(--white);
    text-shadow: 0 2px 18px rgba(6, 16, 34, 0.55);
  }

  .caption em {
    font-style: normal;
    color: var(--teal);
  }

  .play {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    display: grid;
    place-items: center;
    width: 76px;
    height: 76px;
    border: 0;
    border-radius: 50%;
    background: var(--teal);
    color: var(--white);
    cursor: pointer;
    box-shadow: 0 0 0 10px rgba(47, 174, 155, 0.25);
    transition: transform 0.2s ease, background-color 0.2s ease;
  }

  .play:hover {
    transform: translate(-50%, -50%) scale(1.06);
    background: var(--teal-deep);
  }

  .play svg {
    margin-left: 4px;
  }

  .controls {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    display: flex;
    align-items: center;
    gap: 0.9rem;
    padding: 0.8rem 1.25rem;
    color: rgba(255, 255, 255, 0.85);
    background: linear-gradient(180deg, transparent, rgba(6, 16, 34, 0.65));
  }

  .time {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.06em;
  }

  .spacer {
    flex: 1;
  }

  .soon {
    position: absolute;
    left: 50%;
    bottom: 3.6rem;
    transform: translateX(-50%) translateY(8px);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--white);
    background: rgba(14, 39, 80, 0.85);
    border: 1px solid rgba(47, 174, 155, 0.5);
    border-radius: 999px;
    padding: 0.45rem 1rem;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .player.show-soon .soon {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  @media (max-width: 860px) {
    .panel {
      grid-template-columns: 1fr;
    }

    .caption {
      left: 1.25rem;
      top: 1.1rem;
    }
  }
</style>

<script>
  // Placeholder behavior until the final video is delivered.
  const player = document.querySelector("[data-player]");
  let timer: ReturnType<typeof setTimeout> | undefined;
  const scrollBehavior = window.matchMedia("(prefers-reduced-motion: reduce)").matches
    ? ("auto" as const)
    : ("smooth" as const);
  document.querySelectorAll("[data-video-cta]").forEach((el) =>
    el.addEventListener("click", () => {
      player?.classList.add("show-soon");
      player?.scrollIntoView({ behavior: scrollBehavior, block: "center" });
      clearTimeout(timer);
      timer = setTimeout(() => player?.classList.remove("show-soon"), 2400);
    }),
  );
</script>
