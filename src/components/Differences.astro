---
const columns = [
  { key: "standard", label: "Standard trading academy", tone: "muted" },
  { key: "need", label: "What you actually need", tone: "plain" },
  { key: "leverhub", label: "What LeverHub provides", tone: "teal" },
];

const rows = [
  {
    standard: "Charts on day 1.",
    need: "To understand where you are.",
    leverhub: "Assesses your finances, your time, and your goals.",
  },
  {
    standard: "Jargon on day 2.",
    need: "To know what you want.",
    leverhub: "Then takes you to the markets — when you are ready.",
  },
  {
    standard: "Overwhelmed by day 3.",
    need: "To learn at a pace that fits your life.",
    leverhub: "Makes a seamless transition between learning and practice.",
  },
];
---

<section class="section" id="different">
  <div class="container">
    <div class="section-head reveal">
      <p class="eyebrow">Why LeverHub</p>
      <h2>What makes LeverHub different</h2>
      <p class="lede">Other academies start with the market. We start with you.</p>
    </div>

    <div class="compare reveal" role="table" aria-label="How LeverHub compares to a standard trading academy">
      <div class="col-labels" role="row">
        {
          columns.map((col) => (
            <span class:list={["col-label", col.tone]} role="columnheader">
              {col.label}
            </span>
          ))
        }
      </div>

      {
        rows.map((row, i) => (
          <div class="row" role="row">
            <div class="cell muted" role="cell">
              <span class="col-hint" aria-hidden="true">Standard trading academy</span>
              <span class="glyph no" aria-hidden="true">&times;</span>
              <p>{row.standard}</p>
            </div>
            <div class="cell" role="cell">
              <span class="col-hint" aria-hidden="true">What you actually need</span>
              <span class="glyph num" aria-hidden="true">0{i + 1}</span>
              <p>{row.need}</p>
            </div>
            <div class="cell teal" role="cell">
              <span class="col-hint" aria-hidden="true">What LeverHub provides</span>
              <span class="glyph yes" aria-hidden="true">&check;</span>
              <p>{row.leverhub}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .compare {
    display: grid;
    gap: 0.85rem;
  }

  .col-labels {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.85rem;
    padding-inline: 0.25rem;
  }

  .col-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(12, 26, 48, 0.6);
    padding: 0.4rem 1.25rem;
  }

  .col-label.teal {
    color: var(--teal-ink);
  }

  .row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.85rem;
  }

  .cell {
    position: relative;
    background: var(--white);
    border: 1px solid var(--mist);
    border-radius: var(--radius-sm);
    padding: 1.35rem 1.5rem 1.35rem 3.4rem;
    box-shadow: var(--shadow-card);
  }

  .cell p {
    font-size: 0.98rem;
    line-height: 1.55;
  }

  .cell.muted {
    background: var(--mist);
    border-color: var(--mist);
    box-shadow: none;
  }

  .cell.muted p {
    color: rgba(12, 26, 48, 0.6);
  }

  .cell.teal {
    background: var(--teal-wash);
    border-color: #c6e7e0;
  }

  .cell.teal p {
    color: var(--ink);
    font-weight: 500;
  }

  .glyph {
    position: absolute;
    left: 1.15rem;
    top: 1.3rem;
    display: grid;
    place-items: center;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 700;
  }

  .glyph.no {
    background: var(--mist);
    color: rgba(12, 26, 48, 0.6);
  }

  .glyph.num {
    background: var(--paper);
    border: 1px solid var(--mist);
    color: var(--navy);
    font-size: 0.68rem;
  }

  .glyph.yes {
    background: var(--teal);
    color: var(--white);
  }

  .col-hint {
    display: none;
  }

  @media (max-width: 820px) {
    /* Keep column headers in the accessibility tree — the visible
       per-cell .col-hint duplicates are aria-hidden. */
    .col-labels {
      position: absolute;
      width: 1px;
      height: 1px;
      overflow: hidden;
      clip-path: inset(50%);
      white-space: nowrap;
    }

    .row {
      grid-template-columns: 1fr;
      gap: 0.6rem;
      padding-bottom: 1.4rem;
      margin-bottom: 0.35rem;
      border-bottom: 1px dashed var(--mist);
    }

    .row:last-child {
      border-bottom: 0;
      padding-bottom: 0;
    }

    .col-hint {
      display: block;
      font-family: var(--font-mono);
      font-size: 0.62rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(12, 26, 48, 0.6);
      margin-bottom: 0.35rem;
    }

    .cell.teal .col-hint {
      color: var(--teal-ink);
    }
  }
</style>
