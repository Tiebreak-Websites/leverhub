---
// "What makes LeverHub different" — three editorial rows instead of a boxed grid.
// The client's middle column ("what you actually need") becomes the row heading
// that bridges the ✕ standard-academy line and the ✓ LeverHub line.
const rows = [
  {
    need: "To understand where you are.",
    standard: "Charts on day 1.",
    leverhub: "Assesses your finances, your time, and your goals.",
  },
  {
    need: "To know what you want.",
    standard: "Jargon on day 2.",
    leverhub: "Then takes you to the markets — when you are ready.",
  },
  {
    need: "To learn at a pace that fits your life.",
    standard: "Overwhelmed by day 3.",
    leverhub: "Makes a seamless transition between learning and practice.",
  },
];
---

<section class="section" id="different">
  <div class="container">
    <div class="section-head reveal">
      <h2>What makes LeverHub different</h2>
      <p class="lede">Other academies start with the market. We start with you.</p>
    </div>

    <div class="legend reveal" aria-hidden="true">
      <span>What you actually need</span>
      <span class="muted">A standard trading academy</span>
      <span class="teal">What LeverHub provides</span>
    </div>

    <ol class="rows stagger">
      {
        rows.map((row) => (
          <li class="row">
            <h3>{row.need}</h3>
            <p class="them">
              <span class="glyph no" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round">
                  <path d="M6 6l12 12M18 6L6 18" />
                </svg>
              </span>
              <span class="sr-label">A standard trading academy: </span>
              {row.standard}
            </p>
            <p class="us">
              <span class="glyph yes" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M4 12.5l5 5L20 6.5" />
                </svg>
              </span>
              <span class="sr-label">What LeverHub provides: </span>
              {row.leverhub}
            </p>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .legend {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr) minmax(0, 1.3fr);
    gap: clamp(1.5rem, 4vw, 3.5rem);
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--line);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-60);
  }

  .legend .teal {
    color: var(--teal-ink);
  }

  .rows {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
  }

  .row {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr) minmax(0, 1.3fr);
    gap: clamp(1.5rem, 4vw, 3.5rem);
    align-items: center;
    padding-block: clamp(1.5rem, 3vw, 2.25rem);
    border-bottom: 1px solid var(--line);
  }

  .row h3 {
    max-width: 18ch;
  }

  .them,
  .us {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    font-size: 1rem;
    line-height: 1.55;
  }

  .them {
    color: var(--ink-60);
  }

  .us {
    color: var(--ink);
    font-weight: 500;
  }

  .glyph {
    flex: none;
    display: grid;
    place-items: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
  }

  .glyph.no {
    background: var(--mist);
    color: var(--ink-60);
  }

  .glyph.yes {
    background: var(--teal);
    color: var(--white);
  }

  .sr-label {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip-path: inset(50%);
    white-space: nowrap;
  }

  @media (max-width: 820px) {
    .legend {
      display: none;
    }

    .rows {
      border-top: 1px solid var(--line);
    }

    .row {
      grid-template-columns: 1fr;
      gap: 0.9rem;
      align-items: start;
    }

    .row h3 {
      max-width: none;
    }
  }
</style>
