---
// "What makes LeverHub different" — centered convergence diagram.
// Each need sits on a central spine; the standard academy's failure connects
// from the left (crossed out), LeverHub's answer from the right (checked).
const rows = [
  {
    need: "To understand where you are",
    standard: "Charts on day 1.",
    leverhub: "Starts with a Snapshot of your finances, time and goals.",
  },
  {
    need: "To know what you want",
    standard: "Jargon on day 2.",
    leverhub: "Takes you to the markets only when you are ready.",
  },
  {
    need: "To learn at a pace that fits your life",
    standard: "Overwhelmed by day 3.",
    leverhub: "Lets you move from lessons to real practice when you choose.",
  },
];
---

<section class="section grid-paper" id="different">
  <div class="container">
    <div class="section-head reveal">
      <h2>What makes LeverHub different</h2>
      <p class="lede">Other academies start with the market. We start with you.</p>
    </div>

    <div class="diagram">
      <div class="legend reveal" aria-hidden="true">
        <span class="side muted">A standard trading academy</span>
        <span class="side center">What you actually need</span>
        <span class="side teal">What LeverHub provides</span>
      </div>

      <ol class="rows">
        {
          rows.map((row) => (
            <li class="row reveal">
              <p class="them">
                <span class="sr-label">A standard trading academy: </span>
                <span class="glyph no" aria-hidden="true">
                  <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round">
                    <path d="M6 6l12 12M18 6L6 18" />
                  </svg>
                </span>
                {row.standard}
              </p>

              <div class="need">
                <span class="wire left" aria-hidden="true" />
                <h3>
                  <span class="sr-label">What you actually need: </span>
                  {row.need}
                </h3>
                <span class="wire right" aria-hidden="true" />
              </div>

              <p class="us">
                <span class="sr-label">What LeverHub provides: </span>
                <span class="glyph yes" aria-hidden="true">
                  <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 12.5l5 5L20 6.5" />
                  </svg>
                </span>
                {row.leverhub}
              </p>
            </li>
          ))
        }
      </ol>
    </div>
  </div>
</section>

<style>
  .diagram {
    max-width: 1080px;
    margin-inline: auto;
  }

  .legend {
    display: grid;
    grid-template-columns: 1fr 1.1fr 1fr;
    gap: clamp(1rem, 3vw, 2.5rem);
    margin-bottom: 1.75rem;
    font-family: var(--font-sub);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-align: center;
  }

  .legend .muted {
    color: var(--ink-60);
  }

  .legend .center {
    color: var(--ink-black);
  }

  .legend .teal {
    color: var(--teal-ink);
  }

  .rows {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1rem;
  }

  .row {
    display: grid;
    grid-template-columns: 1fr 1.1fr 1fr;
    gap: clamp(1rem, 3vw, 2.5rem);
    align-items: center;
  }

  /* Center node — the need, on the spine */
  .need {
    position: relative;
    text-align: center;
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    padding: 1.4rem 1.5rem;
    box-shadow: var(--shadow-card);
  }

  .need h3 {
    font-size: 1.05rem;
  }

  /* Wires connecting the sides to the node */
  .wire {
    position: absolute;
    top: 50%;
    width: clamp(0.75rem, 2.2vw, 2rem);
    border-top: 2px dashed rgba(12, 26, 48, 0.2);
  }

  .wire.left {
    right: 100%;
  }

  .wire.right {
    left: 100%;
    border-top-color: rgba(47, 174, 155, 0.55);
    border-top-style: solid;
  }

  .them,
  .us {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    font-size: 0.98rem;
    line-height: 1.55;
  }

  .them {
    justify-content: flex-end;
    text-align: right;
    color: var(--ink-60);
    text-decoration: line-through;
    text-decoration-color: rgba(12, 26, 48, 0.25);
    text-decoration-thickness: 1px;
  }

  .them .glyph {
    order: 2;
  }

  .us {
    color: var(--ink);
    font-weight: 500;
  }

  .glyph {
    flex: none;
    display: grid;
    place-items: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
  }

  .glyph.no {
    background: var(--mist);
    color: var(--ink-60);
  }

  .glyph.yes {
    background: var(--teal-bright);
    color: var(--ink-black);
  }

  .sr-label {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip-path: inset(50%);
    white-space: nowrap;
  }

  @media (max-width: 860px) {
    .legend {
      display: none;
    }

    .row {
      grid-template-columns: 1fr;
      gap: 0.75rem;
      padding-bottom: 1.5rem;
      border-bottom: 1px solid var(--line);
    }

    .row:last-child {
      border-bottom: 0;
      padding-bottom: 0;
    }

    .need {
      order: -1;
    }

    .wire {
      display: none;
    }

    .them {
      justify-content: flex-start;
      text-align: left;
    }

    .them .glyph {
      order: 0;
    }
  }
</style>
