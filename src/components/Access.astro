---
const plans = [
  {
    name: "Academy only",
    tag: "Subscription",
    body: "A straightforward subscription. Full access to the LeverHub Academy, your Personal Hub, your Snapshot and your Progress Coach.",
    features: ["LeverHub Academy", "Personal Hub", "Life & Money Snapshot", "Progress Coach"],
    cta: "Start with the Academy",
    featured: false,
  },
  {
    name: "Connected access",
    tag: "Broker connected",
    body: "Connect a broker account to LeverHub and your academy subscription is included for the duration of your package. You are using LeverHub the way it was built — and we reflect that in the pricing.",
    features: [
      "Everything in Academy only",
      "Connected trading dashboard",
      "Trading journal",
      "Academy subscription included for your package duration",
    ],
    cta: "Explore Connected Access",
    featured: true,
  },
];
---

<section class="section" id="access">
  <div class="container">
    <div class="section-head reveal">
      <h2>Two ways in. One destination.</h2>
    </div>

    <div class="plans stagger">
      {
        plans.map((plan) => (
          <article class:list={["plan", "card", { featured: plan.featured }]}>
            <p class="plan-tag">{plan.tag}</p>
            <h3>{plan.name}</h3>
            <p class="plan-body">{plan.body}</p>
            <ul>
              {plan.features.map((feature) => (
                <li>
                  <span class="dot" aria-hidden="true" />
                  {feature}
                </li>
              ))}
            </ul>
            <a href="#faq" class:list={["btn", plan.featured ? "btn-teal" : "btn-outline"]}>
              {plan.cta}
            </a>
          </article>
        ))
      }
    </div>

    <p class="closing reveal">The difference is not what you access. It is how deeply you use it.</p>

    <p class="fine reveal">
      LeverHub is not a broker and does not hold funds or execute trades. Connected access
      requires an account opened directly with a third-party broker. Trading involves risk,
      including the loss of capital.
    </p>
  </div>
</section>

<style>
  .plans {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    align-items: stretch;
  }

  .plan {
    display: grid;
    gap: 1rem;
    align-content: start;
    padding: clamp(2rem, 3.5vw, 2.75rem);
    transition: transform 0.3s var(--ease-out), box-shadow 0.3s var(--ease-out);
  }

  .plan:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-lift);
  }

  @media (prefers-reduced-motion: reduce) {
    .plan:hover {
      transform: none;
    }
  }

  .plan-tag {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--teal-ink);
  }

  .plan-body {
    color: rgba(12, 26, 48, 0.75);
  }

  .plan ul {
    list-style: none;
    margin: 0.25rem 0 0.75rem;
    padding: 0;
    display: grid;
    gap: 0.6rem;
  }

  .plan li {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    font-size: 0.95rem;
    color: var(--ink);
  }

  .dot {
    flex: none;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--teal);
    transform: translateY(-1px);
  }

  .plan .btn {
    justify-self: start;
  }

  /* Deep Navy ground so the teal tag passes AA (teal on Lever Navy is only 3.92:1) */
  .plan.featured {
    background: var(--navy-deep);
    border-color: var(--navy-deep);
  }

  .plan.featured h3,
  .plan.featured li {
    color: var(--white);
  }

  .plan.featured .plan-tag {
    color: var(--teal);
  }

  .plan.featured .plan-body {
    color: rgba(255, 255, 255, 0.75);
  }

  .closing {
    margin-top: 2.5rem;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.25rem, 2.4vw, 1.65rem);
    color: var(--navy);
    max-width: 30ch;
  }

  .fine {
    margin-top: 1.25rem;
    max-width: 680px;
  }

  @media (max-width: 820px) {
    .plans {
      grid-template-columns: minmax(0, 1fr);
    }

    .plan {
      min-width: 0;
    }

    .plan .btn {
      white-space: normal;
      text-align: center;
      line-height: 1.3;
    }
  }
</style>
