---
// Two ways in — pricing-style redesign: light card vs elevated dark featured
// card with glow, check icons and full-width CTAs.
const plans = [
  {
    name: "Academy only",
    tag: "Subscription",
    body: "A straightforward subscription. Full access to the LeverHub Academy, your Personal Hub, your Snapshot and your Progress Coach.",
    features: ["LeverHub Academy", "Personal Hub", "Life & Money Snapshot", "Progress Coach"],
    cta: "Start with the Academy",
    featured: false,
  },
  {
    name: "Connected access",
    tag: "Broker connected",
    body: "Connect a broker account to LeverHub and your academy subscription is included for the duration of your package. You are using LeverHub the way it was built — and we reflect that in the pricing.",
    features: [
      "Everything in Academy only",
      "Connected trading dashboard",
      "Trading journal",
      "Academy subscription included for your package duration",
    ],
    cta: "Explore Connected Access",
    featured: true,
  },
];
---

<section class="section" id="access">
  <div class="container">
    <div class="section-head reveal">
      <h2>Two ways in. One destination.</h2>
      <p class="lede">The difference is not what you access. It is how deeply you use it.</p>
    </div>

    <div class="plans stagger">
      {
        plans.map((plan) => (
          <article class:list={["plan", "card", { featured: plan.featured }]}>
            <p class="plan-tag">{plan.tag}</p>
            <h3>{plan.name}</h3>
            <p class="plan-body">{plan.body}</p>
            <ul>
              {plan.features.map((feature) => (
                <li>
                  <span class="check" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M4 12.5l5 5L20 6.5" />
                    </svg>
                  </span>
                  {feature}
                </li>
              ))}
            </ul>
            <a href="#faq" class:list={["btn", plan.featured ? "btn-teal" : "btn-outline"]}>
              {plan.cta}
            </a>
          </article>
        ))
      }
    </div>

    <p class="fine reveal">
      LeverHub is not a broker and does not hold funds or execute trades. Connected access
      requires an account opened directly with a third-party broker. Trading involves risk,
      including the loss of capital.
    </p>
  </div>
</section>

<style>
  .plans {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    align-items: stretch;
  }

  .plan {
    display: grid;
    grid-template-rows: auto auto auto 1fr auto;
    gap: 1.1rem;
    padding: clamp(2rem, 3.5vw, 3rem);
    transition: transform 0.3s var(--ease-out), box-shadow 0.3s var(--ease-out);
  }

  .plan:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-lift);
  }

  .plan-tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--teal-ink);
  }

  .plan h3 {
    font-size: clamp(1.4rem, 2.2vw, 1.75rem);
  }

  .plan-body {
    color: var(--ink-75);
  }

  .plan ul {
    list-style: none;
    margin: 0.25rem 0 0.75rem;
    padding: 0;
    display: grid;
    gap: 0.75rem;
    align-content: start;
  }

  .plan li {
    display: flex;
    align-items: baseline;
    gap: 0.8rem;
    font-size: 0.98rem;
    font-weight: 500;
    color: var(--ink);
  }

  .check {
    flex: none;
    display: grid;
    place-items: center;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--teal-wash);
    color: var(--teal-deep);
    transform: translateY(3px);
  }

  .plan .btn {
    width: 100%;
  }

  /* Featured — dark, elevated, glowing */
  .plan.featured {
    position: relative;
    overflow: hidden;
    background: var(--navy-deep);
  }

  .plan.featured::before {
    content: "";
    position: absolute;
    inset: -40% -25% 30% 45%;
    background: radial-gradient(60% 70% at 60% 40%, rgba(47, 174, 155, 0.24) 0%, rgba(47, 174, 155, 0) 70%);
    pointer-events: none;
  }

  .plan.featured > * {
    position: relative;
  }

  .plan.featured h3,
  .plan.featured li {
    color: var(--white);
  }

  .plan.featured .plan-tag {
    color: var(--teal);
  }

  .plan.featured .plan-body {
    color: var(--white-75);
  }

  .plan.featured .check {
    background: var(--teal);
    color: var(--white);
  }

  .fine {
    margin-top: 1.75rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .plan:hover {
      transform: none;
    }
  }

  @media (max-width: 820px) {
    .plans {
      grid-template-columns: minmax(0, 1fr);
    }

    .plan {
      min-width: 0;
    }

    .plan .btn {
      white-space: normal;
      line-height: 1.3;
    }
  }
</style>
