---
// Two ways in. One destination. — centered fork diagram: a single origin node
// splits into two branches that land on the two access cards.
const plans = [
  {
    name: "Academy only",
    tag: "Subscription",
    body: "Pay a subscription, get everything: the Academy, your Personal Hub, your Snapshot and your Progress Coach. No broker account needed.",
    features: ["LeverHub Academy", "Personal Hub", "Life & Money Snapshot", "Progress Coach"],
    cta: "Start with the Academy",
    featured: false,
  },
  {
    name: "Connected access",
    tag: "Broker connected",
    body: "Open an account with a broker, connect it to LeverHub, and your subscription is included for the duration of your package.",
    features: [
      "Everything in Academy only",
      "Connected trading dashboard",
      "Trading journal",
      "Academy subscription included for your package duration",
    ],
    cta: "Explore Connected Access",
    featured: true,
  },
];
---

<section class="section grid-paper" id="access">
  <div class="container">
    <div class="section-head reveal">
      <h2>Two ways in. <em>One destination.</em></h2>
      <p class="lede">Both include the full platform. The difference is how you pay for it.</p>
    </div>

    <div class="fork reveal" aria-hidden="true">
      <span class="origin">You</span>
      <svg viewBox="0 0 600 90" preserveAspectRatio="none">
        <path d="M300,0 L300,26 C300,46 280,50 240,50 L120,50 C90,50 80,62 80,90" fill="none" stroke="rgba(12,26,48,0.22)" stroke-width="2" stroke-dasharray="5 6"></path>
        <path d="M300,0 L300,26 C300,46 320,50 360,50 L480,50 C510,50 520,62 520,90" fill="none" stroke="#2fae9b" stroke-width="2"></path>
      </svg>
    </div>


    <div class="plans stagger">
      {
        plans.map((plan) => (
          <article class:list={["plan", "card", { featured: plan.featured }]}>
            <p class="plan-tag">{plan.tag}</p>
            <h3>{plan.name}</h3>
            <p class="plan-body">{plan.body}</p>
            <ul>
              {plan.features.map((feature) => (
                <li>
                  <span class="check" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M4 12.5l5 5L20 6.5" />
                    </svg>
                  </span>
                  {feature}
                </li>
              ))}
            </ul>
            <a href="#faq" class:list={["btn", plan.featured ? "btn-teal" : "btn-outline"]}>
              {plan.cta}
            </a>
          </article>
        ))
      }
    </div>

    <p class="fine reveal">
      LeverHub is not a broker and does not hold funds or execute trades. Connected access
      requires an account opened directly with a third-party broker. Trading involves risk,
      including the loss of capital.
    </p>
  </div>
</section>

<style>
  /* The fork — origin node in normal flow, clear gap below the lede */
  .fork {
    display: grid;
    justify-items: center;
    gap: 1.1rem;
    max-width: 600px;
    margin: 0 auto 0.5rem;
  }

  .origin {
    display: grid;
    place-items: center;
    width: 58px;
    height: 58px;
    border-radius: 50%;
    background: var(--ink-black);
    color: var(--white);
    font-family: var(--font-sub);
    font-weight: 600;
    font-size: 0.9rem;
    box-shadow: 0 0 0 6px rgba(12, 26, 48, 0.06);
  }

  .fork svg {
    width: 100%;
    height: 90px;
  }

  .plans {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    align-items: stretch;
    max-width: 1040px;
    margin-inline: auto;
  }

  .plan {
    display: grid;
    grid-template-rows: auto auto auto 1fr auto;
    gap: 1.1rem;
    padding: clamp(2rem, 3.5vw, 3rem);
    text-align: left;
    transition: transform 0.3s var(--ease-out), box-shadow 0.3s var(--ease-out);
  }

  .plan:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-lift);
  }

  .plan-tag {
    font-family: var(--font-sub);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--teal-ink);
  }

  .plan h3 {
    font-size: clamp(1.4rem, 2.2vw, 1.75rem);
  }

  .plan-body {
    color: var(--ink-75);
  }

  .plan ul {
    list-style: none;
    margin: 0.25rem 0 0.75rem;
    padding: 0;
    display: grid;
    gap: 0.75rem;
    align-content: start;
  }

  .plan li {
    display: flex;
    align-items: baseline;
    gap: 0.8rem;
    font-size: 0.98rem;
    font-weight: 500;
    color: var(--ink);
  }

  .check {
    flex: none;
    display: grid;
    place-items: center;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: var(--teal-wash);
    color: var(--teal-deep);
    transform: translateY(3px);
  }

  .plan .btn {
    width: 100%;
  }

  .plan.featured {
    position: relative;
    overflow: hidden;
    background: var(--ink-black);
  }

  .plan.featured::before {
    content: "";
    position: absolute;
    inset: -40% -25% 30% 45%;
    background: radial-gradient(60% 70% at 60% 40%, rgba(52, 211, 186, 0.22) 0%, rgba(52, 211, 186, 0) 70%);
    pointer-events: none;
  }

  .plan.featured > * {
    position: relative;
  }

  .plan.featured h3,
  .plan.featured li {
    color: var(--white);
  }

  .plan.featured .plan-tag {
    color: var(--teal-bright);
  }

  .plan.featured .plan-body {
    color: var(--white-75);
  }

  .plan.featured .check {
    background: var(--teal-bright);
    color: var(--ink-black);
  }

  /* Never wider than the two cards above it */
  .fine {
    max-width: 1040px;
    margin: 1.75rem auto 0;
    text-align: center;
  }

  @media (prefers-reduced-motion: reduce) {
    .plan:hover {
      transform: none;
    }
  }

  @media (max-width: 820px) {
    .fork {
      display: none;
    }

    .plans {
      grid-template-columns: minmax(0, 1fr);
    }

    .plan {
      min-width: 0;
    }

    .plan .btn {
      white-space: normal;
      line-height: 1.3;
    }
  }
</style>
