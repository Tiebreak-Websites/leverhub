---
// From learning to practice — navy band with an illustrative dashboard mockup
// (pure HTML/CSS, per client visual reference; deliberately learning-centric,
// no profit claims).
const features = [
  {
    label: "Connect your broker",
    icon: `<rect x="4" y="9" width="16" height="11" rx="2"/><path d="M4 13h16M9 9V7a3 3 0 0 1 6 0v2"/>`,
  },
  {
    label: "Track your activity",
    icon: `<circle cx="11" cy="11" r="6.5"/><path d="M15.8 15.8 20 20M8.2 11.6l1.8 1.8 3.4-3.4"/>`,
  },
  {
    label: "Journal every trade",
    icon: `<path d="M5 4.5h11.5A2.5 2.5 0 0 1 19 7v12.5H7A2 2 0 0 1 5 17.5v-13Z"/><path d="M5 16.5h14M9 8.5h6M9 11.5h4"/>`,
  },
  {
    label: "Learn & improve",
    icon: `<path d="M3.5 9 12 5l8.5 4L12 13 3.5 9Z"/><path d="M7 11v4.5c0 1.4 2.2 2.5 5 2.5s5-1.1 5-2.5V11M20.5 9v5"/>`,
  },
];

const goals = [
  { label: "Emergency fund", value: 75 },
  { label: "New car", value: 45 },
];

const lessons = [
  { label: "Economics basics", value: 80 },
  { label: "Market intelligence", value: 60 },
];

const journal = [
  { pair: "EUR/USD", note: "Entry logged · lesson linked" },
  { pair: "Gold", note: "Reviewed with coach" },
  { pair: "US30", note: "Journal note added" },
];
---

<section class="section practice on-navy" id="practice">
  <div class="container inner">
    <div class="copy">
      <p class="eyebrow light reveal">From learning to practice</p>
      <h2 class="reveal">At some point, you have to be in the market to understand it.</h2>
      <p class="body reveal">
        LeverHub is not a video library. It is designed to move you from learning to
        action. When you are ready, you choose a broker, open an account and connect it
        directly to LeverHub. From that point, your dashboard, your trading journal, your
        learning path and your market activity live in one place.
      </p>
      <p class="power reveal">That is when LeverHub becomes most powerful.</p>

      <ul class="features reveal">
        {
          features.map((feature) => (
            <li>
              <span class="icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={feature.icon} />
              </span>
              {feature.label}
            </li>
          ))
        }
      </ul>

      <a href="#access" class="btn btn-teal reveal">Explore Connected Access <span class="arrow" aria-hidden="true">&rarr;</span></a>
    </div>

    <div class="mock-wrap reveal">
      <div class="mock" role="img" aria-label="Illustration of the LeverHub dashboard: balance score, goals, learning progress and trading journal in one place">
        <div class="mock-top">
          <svg class="mock-logo" viewBox="0 0 127 156" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path fill="#ffffff" d="M101.109 0H50.5532V68.789L75.8309 51.8152V25.3138H101.109V156C115.069 156 126.386 144.666 126.386 130.686V25.3138C126.386 11.3338 115.069 0 101.109 0Z"></path>
            <path fill="#2fae9b" d="M50.5554 130.686H25.2777V0C11.3176 0 0 11.3338 0 25.3138V130.686C0 144.666 11.3176 156 25.2777 156H75.8331V82.291L50.5554 99.2648V130.686Z"></path>
          </svg>
          <span class="greet">Good morning, Alex</span>
          <span class="chip">Dashboard</span>
        </div>

        <div class="mock-grid">
          <div class="tile score">
            <span class="tile-label">Balance Score</span>
            <div class="gauge">
              <svg viewBox="0 0 100 100" aria-hidden="true">
                <circle cx="50" cy="50" r="42" fill="none" stroke="rgba(255,255,255,0.12)" stroke-width="9"></circle>
                <circle cx="50" cy="50" r="42" fill="none" stroke="#2fae9b" stroke-width="9" stroke-linecap="round" stroke-dasharray="190 264" transform="rotate(-90 50 50)"></circle>
              </svg>
              <span class="gauge-num">72</span>
            </div>
            <span class="tile-sub">Growing steadily</span>
          </div>

          <div class="tile chart">
            <span class="tile-label">Learning path</span>
            <svg viewBox="0 0 220 70" preserveAspectRatio="none" aria-hidden="true">
              <polyline
                points="0,58 28,52 55,55 85,40 115,44 145,28 180,32 220,14"
                fill="none"
                stroke="#2fae9b"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"></polyline>
              <polyline
                points="0,58 28,52 55,55 85,40 115,44 145,28 180,32 220,14 220,70 0,70"
                fill="url(#mockfade)"
                stroke="none"></polyline>
              <defs>
                <linearGradient id="mockfade" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stop-color="rgba(47,174,155,0.35)"></stop>
                  <stop offset="100%" stop-color="rgba(47,174,155,0)"></stop>
                </linearGradient>
              </defs>
            </svg>
            <span class="tile-sub">Understanding &rarr; action</span>
          </div>

          <div class="tile">
            <span class="tile-label">Goal progress</span>
            {
              goals.map((goal) => (
                <div class="bar-row">
                  <span class="bar-head">
                    <span>{goal.label}</span>
                    <span class="pct">{goal.value}%</span>
                  </span>
                  <span class="bar-track">
                    <span class="bar-fill" style={`width:${goal.value}%`} />
                  </span>
                </div>
              ))
            }
          </div>

          <div class="tile">
            <span class="tile-label">Learning progress</span>
            {
              lessons.map((lesson) => (
                <div class="bar-row">
                  <span class="bar-head">
                    <span>{lesson.label}</span>
                    <span class="pct">{lesson.value}%</span>
                  </span>
                  <span class="bar-track">
                    <span class="bar-fill" style={`width:${lesson.value}%`} />
                  </span>
                </div>
              ))
            }
          </div>

          <div class="tile wide">
            <span class="tile-label">Trading journal</span>
            <ul class="journal">
              {
                journal.map((entry) => (
                  <li>
                    <span class="pair">{entry.pair}</span>
                    <span class="note">{entry.note}</span>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </div>
      <p class="fine">Illustrative interface &mdash; not live market data.</p>
    </div>
  </div>

  <div class="container">
    <p class="fine disclosure reveal">
      LeverHub is the academy and dashboard &mdash; never the broker. You open your account
      directly with a third-party broker. Trading involves risk, including the loss of capital.
    </p>
  </div>
</section>

<style>
  .practice {
    /* Deep Navy at the top so the teal eyebrow passes AA (teal on Lever Navy is 3.92:1) */
    background: linear-gradient(196deg, var(--navy-deep) 0%, var(--navy) 100%);
    color: var(--white);
    overflow: hidden;
  }

  .inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.15fr);
    gap: clamp(2rem, 5vw, 4rem);
    align-items: center;
  }

  .copy {
    display: grid;
    gap: 1.2rem;
    justify-items: start;
  }

  .copy h2 {
    max-width: 20ch;
  }

  .body {
    color: rgba(255, 255, 255, 0.75);
    font-size: 1.02rem;
    max-width: 52ch;
  }

  .power {
    font-family: var(--font-sub);
    /* 20px/700 qualifies as WCAG large text, so teal on the navy gradient passes (3.92:1 > 3:1) */
    font-weight: 700;
    color: var(--teal);
    font-size: 1.25rem;
  }

  .features {
    list-style: none;
    margin: 0.25rem 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.8rem 1.5rem;
    width: 100%;
    max-width: 460px;
  }

  .features li {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    font-family: var(--font-sub);
    font-size: 0.92rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.85);
  }

  .features .icon {
    flex: none;
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border-radius: 10px;
    border: 1px solid rgba(47, 174, 155, 0.45);
    color: var(--teal);
  }

  .features .icon svg {
    width: 20px;
    height: 20px;
  }

  /* ---------- dashboard mockup ---------- */

  .mock-wrap {
    display: grid;
    gap: 0.9rem;
    justify-items: center;
    perspective: 1400px;
  }

  .mock {
    width: 100%;
    background: #0a1c3c;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 18px;
    padding: 1.25rem;
    box-shadow: 0 40px 80px -30px rgba(4, 12, 28, 0.9);
    transform: rotateY(-7deg) rotateX(2deg);
  }

  .mock-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .mock-logo {
    height: 20px;
    width: auto;
  }

  .greet {
    font-family: var(--font-sub);
    font-size: 0.85rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.85);
  }

  .chip {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--teal);
    border: 1px solid rgba(47, 174, 155, 0.5);
    border-radius: 999px;
    padding: 0.3rem 0.7rem;
  }

  .mock-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.8rem;
    padding-top: 1rem;
  }

  .tile {
    background: rgba(255, 255, 255, 0.045);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 12px;
    padding: 0.9rem 1rem;
    display: grid;
    gap: 0.6rem;
    align-content: start;
  }

  .tile.wide {
    grid-column: 1 / -1;
  }

  .tile-label {
    font-family: var(--font-mono);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.58);
  }

  .tile-sub {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    color: var(--teal);
    letter-spacing: 0.08em;
  }

  .score {
    justify-items: center;
    text-align: center;
  }

  .gauge {
    position: relative;
    width: 86px;
    height: 86px;
  }

  .gauge-num {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    font-family: var(--font-sub);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--white);
  }

  .chart svg {
    width: 100%;
    height: 64px;
  }

  .bar-row {
    display: grid;
    gap: 0.3rem;
  }

  .bar-head {
    display: flex;
    justify-content: space-between;
    font-size: 0.72rem;
    color: rgba(255, 255, 255, 0.85);
    font-family: var(--font-sub);
  }

  .pct {
    font-family: var(--font-mono);
    color: var(--teal);
    font-size: 0.66rem;
  }

  .bar-track {
    display: block;
    height: 6px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.1);
    overflow: hidden;
  }

  .bar-fill {
    display: block;
    height: 100%;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--teal-deep), var(--teal));
  }

  .journal {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.45rem;
  }

  .journal li {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding: 0.45rem 0.6rem;
    background: rgba(255, 255, 255, 0.04);
    border-radius: 8px;
  }

  .pair {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    font-weight: 700;
    color: var(--white);
    letter-spacing: 0.06em;
  }

  .note {
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.58);
  }

  .mock-wrap .fine {
    color: rgba(255, 255, 255, 0.58);
  }

  .disclosure {
    margin-top: 2.75rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    max-width: 760px;
  }

  @media (max-width: 960px) {
    .inner {
      grid-template-columns: 1fr;
    }

    .mock {
      transform: none;
    }
  }

  @media (max-width: 480px) {
    .features {
      grid-template-columns: 1fr;
    }

    .mock-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
